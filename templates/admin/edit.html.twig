{% extends 'base.html.twig' %}

{% block title %}Edycja: {{ user.fullName }} — Nauczyciel Assistant{% endblock %}
{% block pretitle_text %}Administracja{% endblock %}
{% block title_text %}Edycja użytkownika{% endblock %}

{% block page_actions %}
    <a href="{{ path('app_admin_index') }}" class="btn btn-outline-secondary btn-sm"><i class="ti ti-arrow-left me-1"></i>Lista użytkowników</a>
{% endblock %}

{% block body %}
<div class="row g-4">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title"><i class="ti ti-user-edit me-2"></i>{{ user.fullName }}</h3>
                <div class="card-actions">
                    <span class="badge bg-secondary-lt">ID: {{ user.id }}</span>
                    <span class="badge bg-secondary-lt">{{ user.createdAt|date('d.m.Y H:i') }}</span>
                </div>
            </div>
            <div class="card-body">
                <form method="post" action="{{ path('app_admin_user_edit', {id: user.id}) }}" data-turbo="false">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label required">Imię i nazwisko</label>
                            <input type="text" name="fullName" class="form-control" value="{{ user.fullName }}" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label required">Email</label>
                            <input type="email" name="email" class="form-control" value="{{ user.email }}" required>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Szkoła</label>
                            <input type="text" name="schoolName" class="form-control" value="{{ user.schoolName }}" placeholder="np. SP nr 5 w Krakowie">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Miasto</label>
                            <input type="text" name="city" class="form-control" value="{{ user.city }}" placeholder="np. Kraków">
                        </div>
                    </div>

                    <hr class="my-3">

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Nowe hasło <span class="text-secondary fw-normal">(zostaw puste = bez zmian)</span></label>
                            <input type="password" name="newPassword" class="form-control" placeholder="Min. 6 znaków" minlength="6">
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Status</label>
                            <label class="form-check form-switch mt-1">
                                <input type="checkbox" name="isActive" value="1" class="form-check-input" {{ user.active ? 'checked' : '' }}>
                                <span class="form-check-label">Aktywny</span>
                            </label>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Rola</label>
                            {% if user == app.user %}
                                <div class="mt-1"><span class="badge bg-red-lt">Admin (Ty)</span></div>
                                <input type="hidden" name="isAdmin" value="1">
                            {% else %}
                                <label class="form-check form-switch mt-1">
                                    <input type="checkbox" name="isAdmin" value="1" class="form-check-input" {{ user.admin ? 'checked' : '' }}>
                                    <span class="form-check-label">Administrator</span>
                                </label>
                            {% endif %}
                        </div>
                    </div>

                    {% if user.totpAuthenticationEnabled %}
                        <div class="alert alert-info d-flex align-items-center gap-2 mb-3">
                            <i class="ti ti-shield-check"></i>
                            <div class="flex-fill">2FA jest włączone dla tego użytkownika</div>
                            <label class="form-check form-switch mb-0">
                                <input type="checkbox" name="reset2fa" value="1" class="form-check-input">
                                <span class="form-check-label text-danger">Wyłącz 2FA</span>
                            </label>
                        </div>
                    {% endif %}

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="ti ti-check me-1"></i>Zapisz zmiany
                        </button>
                        <a href="{{ path('app_admin_index') }}" class="btn btn-outline-secondary">Anuluj</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        {# Quick info card #}
        <div class="card mb-3">
            <div class="card-header"><h3 class="card-title"><i class="ti ti-info-circle me-2"></i>Informacje</h3></div>
            <div class="card-body">
                <div class="datagrid">
                    <div class="datagrid-item">
                        <div class="datagrid-title">ID</div>
                        <div class="datagrid-content">{{ user.id }}</div>
                    </div>
                    <div class="datagrid-item">
                        <div class="datagrid-title">Rejestracja</div>
                        <div class="datagrid-content">{{ user.createdAt|date('d.m.Y H:i') }}</div>
                    </div>
                    <div class="datagrid-item">
                        <div class="datagrid-title">Status</div>
                        <div class="datagrid-content">
                            {% if user.active %}<span class="badge bg-green-lt">Aktywny</span>
                            {% else %}<span class="badge bg-red-lt">Zablokowany</span>{% endif %}
                        </div>
                    </div>
                    <div class="datagrid-item">
                        <div class="datagrid-title">Rola</div>
                        <div class="datagrid-content">
                            {% if user.admin %}<span class="badge bg-red-lt">Administrator</span>
                            {% else %}<span class="badge bg-blue-lt">Nauczyciel</span>{% endif %}
                        </div>
                    </div>
                    <div class="datagrid-item">
                        <div class="datagrid-title">2FA</div>
                        <div class="datagrid-content">
                            {% if user.totpAuthenticationEnabled %}<span class="badge bg-green-lt"><i class="ti ti-shield-check me-1"></i>Włączone</span>
                            {% else %}<span class="badge bg-secondary-lt">Wyłączone</span>{% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Danger zone #}
        {% if user != app.user %}
        <div class="card border-danger">
            <div class="card-header"><h3 class="card-title text-danger"><i class="ti ti-alert-triangle me-2"></i>Strefa niebezpieczna</h3></div>
            <div class="card-body d-flex flex-column gap-2">
                <form method="post" action="{{ path('app_admin_user_reset_password', {id: user.id}) }}" onsubmit="return confirm('Zresetować hasło? Użytkownik otrzyma nowe, tymczasowe hasło.')">
                    <button type="submit" class="btn btn-outline-warning w-100"><i class="ti ti-key me-1"></i>Reset hasła</button>
                </form>
                <form method="post" action="{{ path('app_admin_user_delete', {id: user.id}) }}" onsubmit="return confirm('UWAGA: Usunięcie użytkownika jest NIEODWRACALNE! Wszystkie jego materiały zostaną utracone.')">
                    <button type="submit" class="btn btn-outline-danger w-100"><i class="ti ti-trash me-1"></i>Usuń użytkownika</button>
                </form>
            </div>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
