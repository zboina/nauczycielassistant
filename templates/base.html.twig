<!DOCTYPE html>
<html lang="pl">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="theme-color" content="#1a56db">
        <title>{% block title %}Nauczyciel Assistant{% endblock %}</title>
        <link rel="icon" type="image/png" href="/images/logo.png">
        <link href="https://cdn.jsdelivr.net/npm/@tabler/core@1.2.0/dist/css/tabler.min.css" rel="stylesheet">
        <link href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.31.0/dist/tabler-icons.min.css" rel="stylesheet">
        <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.9/dist/cdn.min.js"></script>
        <style>
            :root {
                --tblr-primary: #1a56db;
                --tblr-primary-rgb: 26, 86, 219;
                --tblr-body-bg: #f1f5f9;
                --tblr-font-sans-serif: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            }
            body { background-color: #f1f5f9 !important; }
            .navbar-brand-image { height: 2rem; }
            .nav-link-icon { opacity: .7; }
            .nav-item.active .nav-link-icon { opacity: 1; }
            .page-pretitle { text-transform: uppercase; letter-spacing: .04em; font-size: .625rem; font-weight: 600; color: #626976; }
            .card { box-shadow: 0 0 4px rgba(0,0,0,.04); transition: box-shadow .2s; }
            .card:hover { box-shadow: 0 1px 8px rgba(0,0,0,.08); }
            .card-link { text-decoration: none; color: inherit; }
            .card-link:hover { color: inherit; }
            .page-wrapper { min-height: 100vh; }
            .navbar-vertical .navbar-nav .nav-link { padding: .25rem .75rem; border-radius: .375rem; margin: 0; font-size: .85rem; }
            .navbar-vertical .navbar-nav .nav-link .nav-link-icon { width: 1.2rem; height: 1.2rem; font-size: .9rem; }
            .navbar-vertical .navbar-nav .nav-link:hover { background: rgba(var(--tblr-primary-rgb), .04); }
            .navbar-vertical .navbar-nav .nav-item.active > .nav-link { background: rgba(var(--tblr-primary-rgb), .08); color: var(--tblr-primary); font-weight: 600; }
            .navbar-vertical .navbar-nav .nav-item.mt-2 { margin-top: .5rem!important; }
            .navbar-vertical .navbar-nav .nav-item.mt-2 .nav-link { padding: .15rem .75rem; font-size: .6rem; }
            .result-box { white-space: pre-wrap; font-family: Georgia, serif; line-height: 1.8; background: #fff; border: 1px solid #e6e8eb; border-radius: .5rem; padding: 1.25rem; }
            .empty-icon i { color: #626976; }
            /* Mobile sidebar fix */
            @media (max-width: 991.98px) {
                .navbar-vertical { position: fixed; top: 0; left: 0; right: 0; z-index: 1050; background: #fff; box-shadow: 0 2px 8px rgba(0,0,0,.15); }
                .navbar-vertical .navbar-collapse { max-height: calc(100vh - 60px); overflow-y: auto; }
                .page-wrapper { padding-top: 60px; }
            }
        </style>
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="d-flex flex-column" data-bs-no-jquery data-turbo="false">
        <script src="https://cdn.jsdelivr.net/npm/@tabler/core@1.2.0/dist/js/tabler.min.js"></script>
        {% block layout %}
        <div class="page">
            {# ── SIDEBAR ─────────────────────────────── #}
            <aside class="navbar navbar-vertical navbar-expand-lg">
                <div class="container-fluid">
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#sidebar-menu">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <h1 class="navbar-brand navbar-brand-autodark">
                        <a href="{{ path('app_dashboard') }}" class="d-flex align-items-center gap-2 text-decoration-none">
                            <img src="/images/logo.png" alt="Logo" style="height:1.8rem;width:auto;">
                            <span style="font-size:.9rem;">Nauczyciel<br><small class="fw-normal" style="font-size:.6rem;opacity:.7;">Assistant</small></span>
                        </a>
                    </h1>
                    <div class="collapse navbar-collapse" id="sidebar-menu">
                        <ul class="navbar-nav pt-lg-2">
                            {# Dashboard #}
                            <li class="nav-item {{ app.request.attributes.get('_route') == 'app_dashboard' ? 'active' }}">
                                <a class="nav-link" href="{{ path('app_dashboard') }}">
                                    <span class="nav-link-icon"><i class="ti ti-layout-dashboard"></i></span>
                                    <span class="nav-link-title">Dashboard</span>
                                </a>
                            </li>

                            <li class="nav-item {{ app.request.attributes.get('_route') starts with 'app_chat' ? 'active' }}">
                                <a class="nav-link" href="{{ path('app_chat') }}">
                                    <span class="nav-link-icon"><i class="ti ti-message-chatbot"></i></span>
                                    <span class="nav-link-title">Asystent AI</span>
                                </a>
                            </li>

                            <li class="nav-item mt-2"><span class="nav-link text-uppercase small fw-bold text-secondary px-2" style="font-size:.625rem;letter-spacing:.05em;">Generatory AI</span></li>

                            <li class="nav-item {{ app.request.attributes.get('_route') starts with 'app_generate_test' ? 'active' }}">
                                <a class="nav-link" href="{{ path('app_generate_test_index') }}">
                                    <span class="nav-link-icon"><i class="ti ti-file-text"></i></span>
                                    <span class="nav-link-title">Sprawdziany</span>
                                </a>
                            </li>
                            <li class="nav-item {{ app.request.attributes.get('_route') starts with 'app_generate_worksheet' ? 'active' }}">
                                <a class="nav-link" href="{{ path('app_generate_worksheet_index') }}">
                                    <span class="nav-link-icon"><i class="ti ti-notebook"></i></span>
                                    <span class="nav-link-title">Karty pracy</span>
                                </a>
                            </li>
                            <li class="nav-item {{ app.request.attributes.get('_route') starts with 'app_generate_parent_info' ? 'active' }}">
                                <a class="nav-link" href="{{ path('app_generate_parent_info_index') }}">
                                    <span class="nav-link-icon"><i class="ti ti-mail-forward"></i></span>
                                    <span class="nav-link-title">Info dla rodziców</span>
                                </a>
                            </li>

                            <li class="nav-item {{ app.request.attributes.get('_route') starts with 'app_essay' ? 'active' }}">
                                <a class="nav-link" href="{{ path('app_essay_index') }}">
                                    <span class="nav-link-icon"><i class="ti ti-writing"></i></span>
                                    <span class="nav-link-title">Wypracowania</span>
                                </a>
                            </li>
                            <li class="nav-item {{ app.request.attributes.get('_route') starts with 'app_exam8' ? 'active' }}">
                                <a class="nav-link" href="{{ path('app_exam8_index') }}">
                                    <span class="nav-link-icon"><i class="ti ti-certificate"></i></span>
                                    <span class="nav-link-title">Egzamin 8-klasisty</span>
                                </a>
                            </li>

                            <li class="nav-item mt-2"><span class="nav-link text-uppercase small fw-bold text-secondary px-2" style="font-size:.625rem;letter-spacing:.05em;">Lektury</span></li>

                            <li class="nav-item {{ app.request.attributes.get('_route') starts with 'app_literature' ? 'active' }}">
                                <a class="nav-link" href="{{ path('app_literature_index') }}">
                                    <span class="nav-link-icon"><i class="ti ti-book-2"></i></span>
                                    <span class="nav-link-title">Baza lektur kl. 4-8</span>
                                </a>
                            </li>
                            <li class="nav-item {{ app.request.attributes.get('_route') starts with 'app_lesson_plan' ? 'active' }}">
                                <a class="nav-link" href="{{ path('app_lesson_plan_index') }}">
                                    <span class="nav-link-icon"><i class="ti ti-clipboard-text"></i></span>
                                    <span class="nav-link-title">Konspekty lekcji</span>
                                </a>
                            </li>

                            <li class="nav-item mt-2"><span class="nav-link text-uppercase small fw-bold text-secondary px-2" style="font-size:.625rem;letter-spacing:.05em;">Teoria</span></li>

                            <li class="nav-item {{ app.request.attributes.get('_route') starts with 'app_theory' ? 'active' }}">
                                <a class="nav-link" href="{{ path('app_theory_index') }}">
                                    <span class="nav-link-icon"><i class="ti ti-school"></i></span>
                                    <span class="nav-link-title">Materiały teoretyczne</span>
                                </a>
                            </li>

                            <li class="nav-item mt-2"><span class="nav-link text-uppercase small fw-bold text-secondary px-2" style="font-size:.625rem;letter-spacing:.05em;">Narzędzia lekcyjne</span></li>

                            <li class="nav-item {{ app.request.attributes.get('_route') starts with 'app_scanner' ? 'active' }}">
                                <a class="nav-link" href="{{ path('app_scanner_index') }}">
                                    <span class="nav-link-icon"><i class="ti ti-scan"></i></span>
                                    <span class="nav-link-title">Skaner odpowiedzi</span>
                                </a>
                            </li>
                            <li class="nav-item {{ app.request.attributes.get('_route') == 'app_classroom_timer' ? 'active' }}">
                                <a class="nav-link" href="{{ path('app_classroom_timer') }}">
                                    <span class="nav-link-icon"><i class="ti ti-clock-hour-3"></i></span>
                                    <span class="nav-link-title">Timer</span>
                                </a>
                            </li>
                            <li class="nav-item {{ app.request.attributes.get('_route') == 'app_classroom_random' ? 'active' }}">
                                <a class="nav-link" href="{{ path('app_classroom_random') }}">
                                    <span class="nav-link-icon"><i class="ti ti-dice-5"></i></span>
                                    <span class="nav-link-title">Losowanie</span>
                                </a>
                            </li>
<li class="nav-item {{ app.request.attributes.get('_route') == 'app_classroom_dictation' ? 'active' }}">
                                <a class="nav-link" href="{{ path('app_classroom_dictation') }}">
                                    <span class="nav-link-icon"><i class="ti ti-microphone"></i></span>
                                    <span class="nav-link-title">Dyktowanie</span>
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </aside>

            {# ── MAIN CONTENT ────────────────────────── #}
            <div class="page-wrapper">
                {# Top header bar #}
                <header class="page-header d-print-none">
                    <div class="container-xl">
                        <div class="row align-items-center">
                            <div class="col">
                                {% block page_pretitle %}<div class="page-pretitle">{{ block('pretitle_text') is defined ? block('pretitle_text') : '' }}</div>{% endblock %}
                                {% block page_title %}<h2 class="page-title">{{ block('title_text') is defined ? block('title_text') : '' }}</h2>{% endblock %}
                            </div>
                            <div class="col-auto">
                                {% block page_actions %}{% endblock %}
                            </div>
                            <div class="col-auto ms-2">
                                <div class="nav-item dropdown">
                                    <a href="#" class="nav-link d-flex lh-1 text-reset p-0" data-bs-toggle="dropdown">
                                        <span class="avatar avatar-sm rounded" style="background-image: url('https://ui-avatars.com/api/?name={{ app.user.fullName|url_encode }}&background=1a56db&color=fff&size=64')"></span>
                                        <div class="d-none d-xl-block ps-2">
                                            <div class="fw-medium">{{ app.user.fullName }}</div>
                                            <div class="mt-1 small text-secondary">{{ app.user.email }}</div>
                                        </div>
                                    </a>
                                    <div class="dropdown-menu dropdown-menu-end dropdown-menu-arrow">
                                        <a href="{{ path('app_profile') }}" class="dropdown-item">
                                            <i class="ti ti-user me-2"></i>Mój profil
                                        </a>
                                        {% if is_granted('ROLE_ADMIN') %}
                                            <a href="{{ path('app_admin_index') }}" class="dropdown-item">
                                                <i class="ti ti-users-group me-2"></i>Zarządzanie użytkownikami
                                            </a>
                                        {% endif %}
                                        <div class="dropdown-divider"></div>
                                        <a href="{{ path('app_logout') }}" class="dropdown-item text-danger">
                                            <i class="ti ti-logout me-2"></i>Wyloguj
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </header>

                {# Flash messages #}
                <div class="container-xl">
                    {% for type in ['success', 'error', 'warning', 'info'] %}
                        {% for message in app.flashes(type) %}
                            <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible mt-3 mb-0" role="alert">
                                <div class="d-flex">
                                    <div>
                                        {% if type == 'success' %}<i class="ti ti-check me-2"></i>
                                        {% elseif type == 'error' %}<i class="ti ti-alert-circle me-2"></i>
                                        {% elseif type == 'warning' %}<i class="ti ti-alert-triangle me-2"></i>
                                        {% else %}<i class="ti ti-info-circle me-2"></i>{% endif %}
                                        {{ message }}
                                    </div>
                                </div>
                                <a class="btn-close" data-bs-dismiss="alert" aria-label="close"></a>
                            </div>
                        {% endfor %}
                    {% endfor %}
                </div>

                {# Page body #}
                <div class="page-body">
                    <div class="container-xl">
                        {% block body %}{% endblock %}
                    </div>
                </div>

                {# Footer #}
                <footer class="footer footer-transparent d-print-none">
                    <div class="container-xl">
                        <div class="row text-center align-items-center">
                            <div class="col-12">
                                <span class="text-secondary">Nauczyciel Assistant &copy; {{ 'now'|date('Y') }} &mdash; Narzędzia AI dla nauczyciela</span>
                            </div>
                        </div>
                    </div>
                </footer>
            </div>
        </div>

        {% endblock %}

        {# ── AI Loading Modal (outside layout block — persists across Turbo) ── #}
        <div class="modal modal-blur fade" id="aiLoadingModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false" data-turbo-permanent>
            <div class="modal-dialog modal-sm modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-body text-center py-4">
                        <div class="mb-3">
                            <div class="spinner-border text-primary" style="width:3rem;height:3rem;" role="status"></div>
                        </div>
                        <h3 class="mb-1">Przetwarzanie AI</h3>
                        <div class="text-secondary" id="aiLoadingMessage">Trwa generowanie treści...</div>
                        <div class="text-secondary mt-2" style="font-size:.8rem;">
                            <i class="ti ti-clock me-1"></i><span id="aiLoadingTimer">0</span>s &mdash; zwykle 10-30 sekund
                        </div>
                        <div class="progress progress-sm mt-3">
                            <div class="progress-bar progress-bar-indeterminate bg-primary"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <script>
        /* ═══ AI Loading Modal ═══ */
        var _aiTimer = null;
        window.showAiLoading = function(msg) {
            var el = document.getElementById('aiLoadingModal');
            if (!el) return;
            document.getElementById('aiLoadingMessage').textContent = msg || 'Trwa generowanie treści...';
            var t = document.getElementById('aiLoadingTimer'), sec = 0;
            if (t) t.textContent = '0';
            clearInterval(_aiTimer);
            _aiTimer = setInterval(function(){ sec++; if(t) t.textContent = sec; }, 1000);
            el.style.display = 'block';
            el.offsetHeight;
            el.classList.add('show');
            document.body.classList.add('modal-open');
            document.body.style.overflow = 'hidden';
            if (!document.querySelector('.modal-backdrop')) {
                var bd = document.createElement('div');
                bd.className = 'modal-backdrop fade show';
                document.body.appendChild(bd);
            }
        };
        window.hideAiLoading = function() {
            clearInterval(_aiTimer);
            var el = document.getElementById('aiLoadingModal');
            if (el) { el.classList.remove('show'); el.style.display = 'none'; }
            document.querySelectorAll('.modal-backdrop').forEach(function(b){ b.remove(); });
            document.body.classList.remove('modal-open');
            document.body.style.overflow = '';
        };
        /* Attach to forms */
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('form[data-ai-loading]').forEach(function(f) {
                f.addEventListener('submit', function(){ window.showAiLoading(f.getAttribute('data-ai-loading')); });
            });
        });
        </script>
    </body>
</html>
