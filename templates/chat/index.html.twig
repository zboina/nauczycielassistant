{% extends 'base.html.twig' %}

{% block title %}Asystent AI — Nauczyciel Assistant{% endblock %}
{% block pretitle_text %}Narzędzia{% endblock %}
{% block title_text %}Asystent AI{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/marked@15/marked.min.js"></script>
{% endblock %}

{% block page_actions %}
    <form method="post" action="{{ path('app_chat_clear') }}" class="d-inline">
        <button type="submit" class="btn btn-outline-secondary btn-sm"><i class="ti ti-trash me-1"></i>Nowa rozmowa</button>
    </form>
{% endblock %}

{% block stylesheets %}
<style>
    .chat-container { display:flex; flex-direction:column; height: calc(100vh - 200px); min-height: 400px; }
    .chat-messages { flex:1; overflow-y:auto; padding:1rem; }
    .chat-input-bar { border-top:1px solid #e6e8eb; padding:1rem; background:#fff; }
    .msg { display:flex; gap:.75rem; margin-bottom:1rem; max-width:85%; }
    .msg-user { margin-left:auto; flex-direction:row-reverse; }
    .msg-avatar { flex-shrink:0; }
    .msg-bubble { padding:.75rem 1rem; border-radius:1rem; line-height:1.6; font-size:.92rem; }
    .msg-user .msg-bubble { background:var(--tblr-primary); color:#fff; border-bottom-right-radius:.25rem; }
    .msg-ai .msg-bubble { background:#f1f5f9; border-bottom-left-radius:.25rem; }
    .msg-ai .msg-bubble img { max-width:100%; border-radius:.5rem; margin-top:.5rem; cursor:pointer; }
    /* Markdown formatting inside chat */
    .msg-bubble h1,.msg-bubble h2,.msg-bubble h3,.msg-bubble h4 { font-size:1rem; font-weight:700; margin:.6rem 0 .3rem; }
    .msg-bubble h1 { font-size:1.1rem; }
    .msg-bubble p { margin:0 0 .4rem; }
    .msg-bubble ul,.msg-bubble ol { margin:0 0 .4rem; padding-left:1.3rem; }
    .msg-bubble li { margin-bottom:.2rem; }
    .msg-bubble code { background:rgba(0,0,0,.06); padding:.1rem .3rem; border-radius:3px; font-size:.85em; }
    .msg-bubble pre { background:rgba(0,0,0,.06); padding:.5rem; border-radius:6px; overflow-x:auto; margin:.4rem 0; }
    .msg-bubble pre code { background:none; padding:0; }
    .msg-bubble strong { font-weight:700; }
    .msg-bubble blockquote { border-left:3px solid #ccc; padding-left:.8rem; margin:.4rem 0; color:#555; }
    .msg-typing .msg-bubble { color:#999; }
    .typing-dots span { animation: blink 1.4s infinite; }
    .typing-dots span:nth-child(2) { animation-delay:.2s; }
    .typing-dots span:nth-child(3) { animation-delay:.4s; }
    @keyframes blink { 0%,100%{opacity:.2} 50%{opacity:1} }
    .chat-suggestions { display:flex; flex-wrap:wrap; gap:.5rem; justify-content:center; padding:2rem 1rem; }
    .chat-suggestions button { font-size:.82rem; }
</style>
{% endblock %}

{% block body %}
{% set history = app.session.get('chat_history', []) %}

<div class="card">
    <div class="chat-container" x-data="chatApp()">
        {# Messages area #}
        <div class="chat-messages" id="chatMessages" x-ref="messages">
            {% if history|length == 0 %}
                <div class="text-center py-5" x-show="messages.length === 0">
                    <img src="/images/logo.png" alt="Logo" style="height:4rem;opacity:.5;" class="mb-3">
                    <h3 class="text-secondary">Witaj! Jestem Twoim asystentem AI.</h3>
                    <p class="text-secondary mb-4">Zadaj pytanie, poproś o pomoc z lekcją lub wygeneruj obrazek.</p>
                    <div class="chat-suggestions">
                        <button class="btn btn-outline-primary btn-sm" @click="sendMessage('Podaj 5 ciekawych pomysłów na lekcję o środkach stylistycznych w klasie 6')">
                            <i class="ti ti-bulb me-1"></i>Pomysły na lekcję
                        </button>
                        <button class="btn btn-outline-green btn-sm" @click="sendMessage('Wyjaśnij różnicę między metonimią a synekdochą z przykładami')">
                            <i class="ti ti-book me-1"></i>Wyjaśnij pojęcie
                        </button>
                        <button class="btn btn-outline-purple btn-sm" @click="sendMessage('Zrób plakat edukacyjny o rodzajach literackich: epika, liryka, dramat')">
                            <i class="ti ti-photo me-1"></i>Wygeneruj plakat
                        </button>
                        <button class="btn btn-outline-orange btn-sm" @click="sendMessage('Jak motywować uczniów do czytania lektur? Podaj praktyczne metody.')">
                            <i class="ti ti-heart me-1"></i>Porady dydaktyczne
                        </button>
                        <button class="btn btn-outline-teal btn-sm" @click="sendMessage('Przeanalizuj tę stronę i zrób streszczenie: https://pl.wikipedia.org/wiki/Adam_Mickiewicz')">
                            <i class="ti ti-world me-1"></i>Analizuj stronę WWW
                        </button>
                    </div>
                </div>
            {% endif %}

            {# Existing history #}
            {% for msg in history %}
                <div class="msg {{ msg.role == 'user' ? 'msg-user' : 'msg-ai' }}">
                    <div class="msg-avatar">
                        {% if msg.role == 'user' %}
                            <span class="avatar avatar-sm rounded" style="background-image:url('https://ui-avatars.com/api/?name={{ app.user.fullName|url_encode }}&background=1a56db&color=fff&size=32')"></span>
                        {% else %}
                            <span class="avatar avatar-sm rounded bg-purple-lt"><i class="ti ti-robot"></i></span>
                        {% endif %}
                    </div>
                    <div class="msg-bubble">
                        {% if msg.role == 'user' %}
                            {{ msg.content }}
                        {% else %}
                            <div class="md-content" data-md="{{ msg.content|e('html_attr') }}"></div>
                        {% endif %}
                        {% if msg.image is defined and msg.image %}
                            <img src="{{ msg.image }}" alt="Wygenerowany obrazek" loading="lazy"
                                 onclick="window.open(this.src,'_blank')">
                        {% endif %}
                    </div>
                </div>
            {% endfor %}

            {# Dynamic messages from Alpine #}
            <template x-for="(msg, i) in messages" :key="i">
                <div class="msg" :class="msg.role === 'user' ? 'msg-user' : 'msg-ai'">
                    <div class="msg-avatar">
                        <template x-if="msg.role === 'user'">
                            <span class="avatar avatar-sm rounded" style="background-image:url('https://ui-avatars.com/api/?name={{ app.user.fullName|url_encode }}&background=1a56db&color=fff&size=32')"></span>
                        </template>
                        <template x-if="msg.role !== 'user'">
                            <span class="avatar avatar-sm rounded bg-purple-lt"><i class="ti ti-robot"></i></span>
                        </template>
                    </div>
                    <div class="msg-bubble">
                        <div x-html="msg.html || msg.content"></div>
                        <template x-if="msg.image">
                            <img :src="msg.image" alt="Wygenerowany obrazek" loading="lazy"
                                 style="max-width:100%;border-radius:.5rem;margin-top:.5rem;cursor:pointer;"
                                 @click="window.open(msg.image,'_blank')">
                        </template>
                    </div>
                </div>
            </template>

            {# Typing indicator #}
            <div class="msg msg-ai msg-typing" x-show="loading">
                <div class="msg-avatar"><span class="avatar avatar-sm rounded bg-purple-lt"><i class="ti ti-robot"></i></span></div>
                <div class="msg-bubble">
                    <span class="typing-dots"><span>.</span><span>.</span><span>.</span></span> Myślę...
                </div>
            </div>
        </div>

        {# Input bar #}
        <div class="chat-input-bar">
            <form @submit.prevent="send()" class="d-flex gap-2">
                <input type="text" class="form-control" x-model="input" x-ref="chatInput"
                       placeholder="Zadaj pytanie, wklej URL strony lub poproś o obrazek..." :disabled="loading" autofocus>
                <button type="submit" class="btn btn-primary" :disabled="loading || !input.trim()">
                    <i class="ti ti-send"></i>
                </button>
            </form>
            <div class="text-center mt-2" style="font-size:.7rem;color:#aaa;">
                <i class="ti ti-info-circle me-1"></i>Wklej URL — AI przeanalizuje stronę | Poproś o "plakat" — AI wygeneruje obrazek
            </div>
        </div>
    </div>
</div>

<script>
function chatApp() {
    return {
        messages: [],
        input: '',
        loading: false,

        async send() {
            var text = this.input.trim();
            if (!text || this.loading) return;
            this.sendMessage(text);
        },

        async sendMessage(text) {
            this.input = '';
            this.messages.push({role: 'user', content: text});
            this.scrollDown();
            this.loading = true;

            try {
                var fd = new FormData();
                fd.append('message', text);
                var resp = await fetch('{{ path("app_chat_send") }}', {
                    method: 'POST',
                    body: fd,
                    headers: {'X-Requested-With': 'XMLHttpRequest'}
                });
                var data = await resp.json();

                if (data.error) {
                    this.messages.push({role: 'assistant', content: 'Błąd: ' + data.error});
                } else {
                    var html = typeof marked !== 'undefined' ? marked.parse(data.text || '') : (data.text || '').replace(/\n/g, '<br>');
                    this.messages.push({
                        role: 'assistant',
                        content: data.text,
                        html: html,
                        image: data.image || null,
                    });
                }
            } catch(e) {
                this.messages.push({role: 'assistant', content: 'Błąd połączenia: ' + e.message});
            } finally {
                this.loading = false;
                this.scrollDown();
                this.$nextTick(() => this.$refs.chatInput.focus());
            }
        },

        scrollDown() {
            this.$nextTick(() => {
                var el = this.$refs.messages;
                if (el) el.scrollTop = el.scrollHeight;
            });
        }
    };
}

// Render Markdown in history messages loaded from Twig
document.addEventListener('DOMContentLoaded', function() {
    if (typeof marked === 'undefined') return;
    document.querySelectorAll('.md-content[data-md]').forEach(function(el) {
        el.innerHTML = marked.parse(el.getAttribute('data-md'));
    });
});
</script>
{% endblock %}
