{% extends 'base.html.twig' %}

{% block title %}Losowanie — Nauczyciel Assistant{% endblock %}
{% block pretitle_text %}Narzędzia lekcyjne{% endblock %}
{% block title_text %}Losowanie uczniów{% endblock %}

{% block body %}
<div x-data="randomApp()" x-init="init()">
<div class="row g-4">
    {# Left — settings #}
    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header"><h3 class="card-title"><i class="ti ti-settings me-2"></i>Ustawienia</h3></div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Liczba uczniów w klasie</label>
                    <input type="number" class="form-control" min="1" max="50" x-model.number="totalStudents" @change="reset()">
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-secondary btn-sm flex-fill" @click="setTotal(25)">25</button>
                    <button class="btn btn-outline-secondary btn-sm flex-fill" @click="setTotal(28)">28</button>
                    <button class="btn btn-outline-secondary btn-sm flex-fill" @click="setTotal(30)">30</button>
                    <button class="btn btn-outline-secondary btn-sm flex-fill" @click="setTotal(32)">32</button>
                    <button class="btn btn-outline-secondary btn-sm flex-fill" @click="setTotal(35)">35</button>
                </div>
            </div>
        </div>

        {# Number grid #}
        <div class="card mb-3" x-show="totalStudents > 0">
            <div class="card-header">
                <h3 class="card-title">Numery</h3>
                <div class="card-actions">
                    <button class="btn btn-sm btn-ghost-secondary" @click="reset()"><i class="ti ti-refresh me-1"></i>Reset</button>
                </div>
            </div>
            <div class="card-body">
                <div class="d-flex flex-wrap gap-1">
                    <template x-for="n in totalStudents" :key="n">
                        <button class="btn btn-sm" style="width:42px;"
                                :class="{
                                    'btn-success': drawn.includes(n) && n !== selectedNumber,
                                    'btn-primary': n === selectedNumber,
                                    'btn-danger opacity-50': excluded.includes(n),
                                    'btn-outline-secondary': !drawn.includes(n) && !excluded.includes(n) && n !== selectedNumber
                                }"
                                @click="toggleExclude(n)"
                                :title="excluded.includes(n) ? 'Kliknij aby przywrócić' : 'Kliknij aby wykluczyć (nieobecny)'"
                                x-text="n">
                        </button>
                    </template>
                </div>
                <div class="mt-3 text-secondary small">
                    <i class="ti ti-info-circle me-1"></i>Kliknij numer, aby wykluczyć nieobecnego ucznia
                </div>
            </div>
            <div class="card-footer text-secondary small">
                <span x-text="availableCount"></span> dostępnych /
                <span x-text="drawn.length"></span> wylosowanych /
                <span x-text="excluded.length"></span> nieobecnych
            </div>
        </div>
    </div>

    {# Right — draw area #}
    <div class="col-lg-8">
        <div class="card" style="overflow:hidden;">
            <div class="card-body text-center py-5" style="position:relative;">
                {# Confetti canvas #}
                <canvas id="confettiCanvas" style="position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:5;"></canvas>

                <div style="min-height: 220px; display: flex; align-items: center; justify-content: center; position: relative;">
                    <div x-show="totalStudents === 0" class="text-secondary" style="font-size: 1.3rem;">
                        Podaj liczbę uczniów w klasie
                    </div>
                    <div x-show="totalStudents > 0 && !selectedNumber && !spinning && availableCount > 0" class="text-secondary" style="font-size: 1.3rem;">
                        Kliknij "Losuj"
                    </div>
                    <div x-show="totalStudents > 0 && availableCount === 0 && !spinning && !selectedNumber" class="text-success fw-medium" style="font-size: 1.3rem;">
                        Wszyscy wylosowani! Kliknij "Reset".
                    </div>

                    {# Slot-machine style spinner #}
                    <div x-show="spinning" class="slot-container">
                        <div class="slot-window">
                            <div class="slot-number" x-text="spinningNumber"
                                 :style="'color:' + spinColor"></div>
                        </div>
                    </div>

                    {# Winner reveal #}
                    <div x-show="selectedNumber && !spinning" class="winner-reveal" x-text="selectedNumber"></div>
                </div>

                <div class="d-flex justify-content-center gap-3 align-items-center mt-3">
                    <button class="btn btn-primary btn-lg px-5 btn-draw" @click="draw()" :disabled="totalStudents === 0 || availableCount === 0 || spinning">
                        <i class="ti ti-dice-5 me-2"></i> Losuj!
                    </button>
                    <label class="form-check d-inline-flex align-items-center gap-2 mb-0">
                        <input class="form-check-input" type="checkbox" x-model="noRepeat">
                        <span class="form-check-label">Bez powtórzeń</span>
                    </label>
                </div>
            </div>
        </div>

        {# History #}
        <div class="card mt-3" x-show="history.length > 0">
            <div class="card-header">
                <h3 class="card-title"><i class="ti ti-history me-2"></i>Historia losowań</h3>
                <div class="card-actions"><button class="btn btn-sm btn-ghost-secondary" @click="history = []">Wyczyść</button></div>
            </div>
            <div class="table-responsive" style="max-height: 250px; overflow-y: auto;">
                <table class="table table-vcenter card-table table-sm">
                    <tbody>
                        <template x-for="(h, i) in history.slice().reverse()" :key="i">
                            <tr>
                                <td style="width:60px;"><span class="badge bg-primary-lt" x-text="'#' + (history.length - i)"></span></td>
                                <td><span class="fw-bold" style="font-size:1.1rem;font-family:'Courier New',monospace;" x-text="'Numer ' + h.number"></span></td>
                                <td class="text-secondary text-end" x-text="h.time"></td>
                            </tr>
                        </template>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
</div>

<style>
.slot-container {
    perspective: 400px;
}
.slot-window {
    width: 180px; height: 140px;
    background: linear-gradient(180deg, rgba(0,0,0,.06) 0%, transparent 30%, transparent 70%, rgba(0,0,0,.06) 100%);
    border-radius: 16px;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
    position: relative;
    border: 3px solid #dee2e6;
    box-shadow: inset 0 2px 8px rgba(0,0,0,.08);
}
.slot-number {
    font-size: 6rem;
    font-weight: 900;
    font-family: 'Courier New', monospace;
    animation: slotSpin .08s ease-in-out infinite;
    text-shadow: 0 2px 4px rgba(0,0,0,.1);
}
@keyframes slotSpin {
    0%   { transform: translateY(-20px); opacity: 0.3; }
    50%  { transform: translateY(0); opacity: 1; }
    100% { transform: translateY(20px); opacity: 0.3; }
}
.winner-reveal {
    font-size: 8rem;
    font-weight: 900;
    font-family: 'Courier New', monospace;
    color: var(--tblr-primary);
    animation: winnerPop .6s cubic-bezier(.17,.67,.24,1.2) forwards;
    text-shadow: 0 4px 20px rgba(var(--tblr-primary-rgb), .3);
}
@keyframes winnerPop {
    0%   { transform: scale(0.1) rotate(-10deg); opacity: 0; }
    50%  { transform: scale(1.2) rotate(3deg); opacity: 1; }
    70%  { transform: scale(0.95) rotate(-1deg); }
    100% { transform: scale(1) rotate(0); }
}
.btn-draw {
    transition: transform .1s;
}
.btn-draw:active {
    transform: scale(0.95);
}
</style>

<script>
function randomApp() {
    return {
        totalStudents: 0,
        drawn: [],
        excluded: [],
        selectedNumber: null,
        spinningNumber: '',
        spinning: false,
        noRepeat: true,
        history: [],

        init() {
            const saved = localStorage.getItem('nauczyciel_random_total');
            if (saved) this.totalStudents = parseInt(saved) || 0;
            const savedExcl = localStorage.getItem('nauczyciel_random_excluded');
            if (savedExcl) try { this.excluded = JSON.parse(savedExcl); } catch(e) {}
        },

        setTotal(n) {
            this.totalStudents = n;
            this.reset();
        },

        reset() {
            this.drawn = [];
            this.selectedNumber = null;
            localStorage.setItem('nauczyciel_random_total', this.totalStudents);
        },

        toggleExclude(n) {
            if (this.excluded.includes(n)) {
                this.excluded = this.excluded.filter(x => x !== n);
            } else {
                this.excluded.push(n);
                this.drawn = this.drawn.filter(x => x !== n);
            }
            localStorage.setItem('nauczyciel_random_excluded', JSON.stringify(this.excluded));
        },

        get availableCount() {
            let count = 0;
            for (let i = 1; i <= this.totalStudents; i++) {
                if (!this.excluded.includes(i) && (!this.noRepeat || !this.drawn.includes(i))) count++;
            }
            return count;
        },

        getAvailableNumbers() {
            const nums = [];
            for (let i = 1; i <= this.totalStudents; i++) {
                if (!this.excluded.includes(i) && (!this.noRepeat || !this.drawn.includes(i))) nums.push(i);
            }
            return nums;
        },

        spinColor: '#333',

        draw() {
            const available = this.getAvailableNumbers();
            if (!available.length) return;

            this.spinning = true;
            this.selectedNumber = null;
            this.spinColor = '#333';

            const winner = available[Math.floor(Math.random() * available.length)];
            const totalTicks = 25 + Math.floor(Math.random() * 10);
            let tick = 0;
            const colors = ['#1a56db','#d63939','#2fb344','#f76707','#ae3ec9','#0ca678'];

            const doTick = () => {
                tick++;
                // Show random number (last 3 ticks show winner to build suspense)
                if (tick >= totalTicks - 2) {
                    this.spinningNumber = winner;
                } else {
                    this.spinningNumber = available[Math.floor(Math.random() * available.length)];
                }
                this.spinColor = colors[tick % colors.length];

                if (tick >= totalTicks) {
                    // DONE — reveal winner
                    this.spinningNumber = '';
                    this.spinning = false;
                    this.selectedNumber = winner;
                    this.drawn.push(winner);
                    this.history.push({
                        number: winner,
                        time: new Date().toLocaleTimeString('pl-PL', {hour:'2-digit', minute:'2-digit', second:'2-digit'})
                    });
                    playWinSound();
                    launchConfetti();
                    return;
                }

                // Easing — starts fast, slows down at end
                const progress = tick / totalTicks;
                const delay = 50 + Math.pow(progress, 3) * 400;
                setTimeout(doTick, delay);
            };
            doTick();
        }
    };
}

// ─── Win sound ───────────────────────────────
function playWinSound() {
    try {
        const ctx = new (window.AudioContext || window.webkitAudioContext)();
        const notes = [523.25, 659.25, 783.99, 1046.50]; // C5 E5 G5 C6
        notes.forEach((freq, i) => {
            const osc = ctx.createOscillator();
            const gain = ctx.createGain();
            osc.type = 'sine';
            osc.frequency.value = freq;
            gain.gain.value = 0.15;
            gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.15 * i + 0.4);
            osc.connect(gain);
            gain.connect(ctx.destination);
            osc.start(ctx.currentTime + 0.1 * i);
            osc.stop(ctx.currentTime + 0.1 * i + 0.4);
        });
        setTimeout(() => ctx.close().catch(()=>{}), 2000);
    } catch(e) {}
}

// ─── Confetti ────────────────────────────────
function launchConfetti() {
    const canvas = document.getElementById('confettiCanvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    canvas.width = canvas.offsetWidth;
    canvas.height = canvas.offsetHeight;

    const colors = ['#1a56db','#d63939','#2fb344','#f76707','#ae3ec9','#f59f00','#0ca678','#e64980'];
    const particles = [];

    for (let i = 0; i < 80; i++) {
        particles.push({
            x: canvas.width / 2 + (Math.random() - 0.5) * 60,
            y: canvas.height / 2,
            vx: (Math.random() - 0.5) * 16,
            vy: -Math.random() * 12 - 4,
            w: Math.random() * 8 + 4,
            h: Math.random() * 6 + 3,
            color: colors[Math.floor(Math.random() * colors.length)],
            rotation: Math.random() * 360,
            rotSpeed: (Math.random() - 0.5) * 15,
            gravity: 0.25 + Math.random() * 0.15,
            life: 1,
        });
    }

    let frame = 0;
    function tick() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        let alive = false;

        particles.forEach(p => {
            p.x += p.vx;
            p.vy += p.gravity;
            p.y += p.vy;
            p.rotation += p.rotSpeed;
            p.life -= 0.012;
            p.vx *= 0.99;

            if (p.life <= 0) return;
            alive = true;

            ctx.save();
            ctx.translate(p.x, p.y);
            ctx.rotate(p.rotation * Math.PI / 180);
            ctx.globalAlpha = Math.max(0, p.life);
            ctx.fillStyle = p.color;
            ctx.fillRect(-p.w / 2, -p.h / 2, p.w, p.h);
            ctx.restore();
        });

        frame++;
        if (alive && frame < 180) {
            requestAnimationFrame(tick);
        } else {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
        }
    }
    requestAnimationFrame(tick);
}
</script>
{% endblock %}
