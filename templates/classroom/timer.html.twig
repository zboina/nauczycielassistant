{% extends 'base.html.twig' %}

{% block title %}Timer — Nauczyciel Assistant{% endblock %}
{% block pretitle_text %}Narzędzia lekcyjne{% endblock %}
{% block title_text %}Timer lekcji{% endblock %}

{% block body %}
<div x-data="timerApp()" x-init="init()">
    {# Preset buttons #}
    <div class="card mb-3" x-show="!fullscreen">
        <div class="card-body py-3">
            <div class="d-flex flex-wrap gap-2 align-items-center">
                <span class="text-secondary fw-medium me-1">Czas:</span>
                <template x-for="p in presets" :key="p">
                    <button class="btn btn-sm btn-outline-primary" @click="setPreset(p)" x-text="p + ' min'"></button>
                </template>
                <div class="vr mx-1"></div>
                <div class="input-group input-group-sm" style="width: 140px;">
                    <input type="number" class="form-control" placeholder="min" min="1" max="120" x-model.number="customMinutes">
                    <button class="btn btn-primary" @click="setPreset(customMinutes)"><i class="ti ti-clock"></i></button>
                </div>
                <div class="vr mx-1"></div>
                <div class="btn-group btn-group-sm">
                    <button class="btn" :class="mode === 'countdown' ? 'btn-primary' : 'btn-outline-primary'" @click="setMode('countdown')">
                        <i class="ti ti-clock-down me-1"></i>Odliczanie
                    </button>
                    <button class="btn" :class="mode === 'stopwatch' ? 'btn-primary' : 'btn-outline-primary'" @click="setMode('stopwatch')">
                        <i class="ti ti-clock-up me-1"></i>Stoper
                    </button>
                </div>
            </div>
        </div>
    </div>

    {# Timer display #}
    <div class="card" :class="fullscreen ? 'timer-fullscreen' : ''">
        <div class="card-body text-center py-5" :style="fullscreen ? 'background: #1a1a2e; min-height: 100vh; display: flex; flex-direction: column; justify-content: center;' : ''">

            <div class="progress mb-4" style="height: 6px;" x-show="mode === 'countdown' && totalSeconds > 0">
                <div class="progress-bar" :class="progressColor" :style="'width: ' + progressPercent + '%'" style="transition: width 1s linear;"></div>
            </div>

            <div :style="fullscreen ? 'font-size: 18vw; color: white;' : 'font-size: 7rem;'"
                 style="font-family: 'Courier New', monospace; font-weight: bold; line-height: 1; letter-spacing: 0.05em;"
                 x-text="displayTime"></div>

            <div class="mt-3 mb-4" :class="fullscreen ? 'text-white' : 'text-secondary'" style="font-size: 1.1rem;">
                <span x-show="!running && seconds === 0 && mode === 'countdown'" x-text="totalSeconds > 0 ? 'Gotowy' : 'Wybierz czas'"></span>
                <span x-show="running">Trwa...</span>
                <span x-show="!running && seconds > 0 && mode === 'countdown'">Pauza</span>
                <span x-show="!running && mode === 'stopwatch' && elapsed > 0">Pauza</span>
                <span x-show="finished" class="text-danger fw-bold" style="font-size: 1.3rem;">CZAS MINĄŁ!</span>
            </div>

            <div class="d-flex justify-content-center gap-2">
                <button class="btn btn-lg" :class="running ? 'btn-warning' : 'btn-success'" @click="toggleTimer()" :disabled="totalSeconds === 0 && mode === 'countdown' && !running">
                    <i class="ti" :class="running ? 'ti-player-pause' : 'ti-player-play'"></i>
                    <span x-text="running ? 'Pauza' : 'Start'" class="ms-1"></span>
                </button>
                <button class="btn btn-lg btn-outline-secondary" @click="resetTimer()">
                    <i class="ti ti-refresh me-1"></i>Reset
                </button>
                <button class="btn btn-lg btn-outline-primary" @click="toggleFullscreen()">
                    <i class="ti" :class="fullscreen ? 'ti-arrows-minimize' : 'ti-arrows-maximize'"></i>
                </button>
            </div>

            <div x-show="fullscreen && !running && seconds === 0" class="mt-5">
                <div class="d-flex flex-wrap justify-content-center gap-2">
                    <template x-for="p in presets" :key="'fs'+p">
                        <button class="btn btn-lg btn-outline-light" @click="setPreset(p)" x-text="p + ' min'"></button>
                    </template>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.timer-fullscreen { position: fixed !important; top: 0; left: 0; right: 0; bottom: 0; z-index: 9999; border-radius: 0 !important; margin: 0 !important; }
</style>
<script>
function timerApp() {
    return {
        mode: 'countdown', presets: [2, 5, 10, 15, 20, 30, 45], customMinutes: 10,
        totalSeconds: 0, seconds: 0, elapsed: 0, running: false, finished: false, fullscreen: false, interval: null, audioCtx: null,
        init() {},
        setMode(m) { this.resetTimer(); this.mode = m; },
        setPreset(min) { this.resetTimer(); this.totalSeconds = min * 60; this.seconds = this.totalSeconds; },
        toggleTimer() { this.running ? this.pause() : this.start(); },
        start() { if (this.finished) this.resetTimer(); this.running = true; this.finished = false; this.interval = setInterval(() => this.tick(), 1000); },
        pause() { this.running = false; clearInterval(this.interval); },
        resetTimer() { this.running = false; this.finished = false; clearInterval(this.interval); this.mode === 'countdown' ? this.seconds = this.totalSeconds : this.elapsed = 0; },
        tick() {
            if (this.mode === 'countdown') { if (this.seconds > 0) this.seconds--; if (this.seconds === 0) { this.running = false; this.finished = true; clearInterval(this.interval); this.playAlarm(); } }
            else this.elapsed++;
        },
        playAlarm() { try { this.audioCtx = this.audioCtx || new (window.AudioContext || window.webkitAudioContext)(); for (let i = 0; i < 3; i++) { const o = this.audioCtx.createOscillator(), g = this.audioCtx.createGain(); o.connect(g); g.connect(this.audioCtx.destination); o.frequency.value = 880; o.type = 'sine'; g.gain.value = 0.3; const s = this.audioCtx.currentTime + i * 0.5; o.start(s); o.stop(s + 0.3); } } catch(e) {} },
        toggleFullscreen() { this.fullscreen = !this.fullscreen; },
        get displayTime() { const t = this.mode === 'countdown' ? this.seconds : this.elapsed; return String(Math.floor(t/60)).padStart(2,'0') + ':' + String(t%60).padStart(2,'0'); },
        get progressPercent() { return this.totalSeconds === 0 ? 100 : (this.seconds / this.totalSeconds) * 100; },
        get progressColor() { const p = this.progressPercent; return p > 50 ? 'bg-success' : p > 20 ? 'bg-warning' : 'bg-danger'; }
    };
}
</script>
{% endblock %}
