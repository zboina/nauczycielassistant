{% extends 'base.html.twig' %}

{% block title %}Generator dyktand — Nauczyciel Assistant{% endblock %}
{% block pretitle_text %}Generatory AI{% endblock %}
{% block title_text %}Generator dyktand ortograficznych{% endblock %}

{% block page_actions %}
    <a href="{{ path('app_dictation_gen_index') }}" class="btn btn-outline-secondary btn-sm"><i class="ti ti-arrow-left me-1"></i>Dyktanda</a>
{% endblock %}

{% block body %}
<div class="row g-4">
    {# Form #}
    <div class="col-lg-4">
        <div class="card sticky-top" style="top:1rem;">
            <div class="card-header"><h3 class="card-title"><i class="ti ti-adjustments me-2"></i>Parametry dyktanda</h3></div>
            <div class="card-body">
                <form method="post" action="{{ path('app_dictation_gen_generate') }}" data-ai-loading="Trwa generowanie dyktanda...">
                    <div class="mb-3">
                        <label class="form-label required">Typ dyktanda</label>
                        <div class="d-flex gap-2">
                            <label class="form-selectgroup-item flex-fill">
                                <input type="radio" name="type" value="classic" class="form-selectgroup-input" checked>
                                <span class="form-selectgroup-label text-center"><i class="ti ti-file-text me-1"></i>Klasyczne</span>
                            </label>
                            <label class="form-selectgroup-item flex-fill">
                                <input type="radio" name="type" value="quiz" class="form-selectgroup-input">
                                <span class="form-selectgroup-label text-center"><i class="ti ti-list-check me-1"></i>Testowe</span>
                            </label>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label">Klasa</label>
                            <select name="classLevel" class="form-select">
                                {% for cl in ['4','5','6','7','8'] %}
                                    <option value="{{ cl }}" {{ cl == '6' ? 'selected' : '' }}>Klasa {{ cl }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label">Trudność</label>
                            <select name="difficulty" class="form-select">
                                <option value="łatwy">Łatwy</option>
                                <option value="średni" selected>Średni</option>
                                <option value="trudny">Trudny</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Długość (słów)</label>
                        <select name="wordCount" class="form-select">
                            <option value="60">Krótkie (~60 słów)</option>
                            <option value="100" selected>Średnie (~100 słów)</option>
                            <option value="150">Długie (~150 słów)</option>
                            <option value="200">Bardzo długie (~200 słów)</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Zakres ortograficzny</label>
                        <select name="spellingFocus" class="form-select">
                            <option value="all">Wszystkie trudności</option>
                            <option value="ou">ó / u</option>
                            <option value="rzz">rz / ż</option>
                            <option value="chh">ch / h</option>
                            <option value="nie">"nie" z częściami mowy</option>
                            <option value="wielka">Wielka i mała litera</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="ti ti-sparkles me-2"></i>Generuj dyktando
                    </button>
                </form>
            </div>
        </div>
    </div>

    {# Preview #}
    <div class="col-lg-8">
        {% if data %}
            <div class="card mb-3">
                <div class="card-stamp"><div class="card-stamp-icon bg-orange"><i class="ti ti-writing-sign"></i></div></div>
                <div class="card-header">
                    <h3 class="card-title">{{ data.title }}</h3>
                    <div class="card-actions">
                        <form method="post" action="{{ path('app_dictation_gen_save') }}" class="d-inline">
                            <button type="submit" class="btn btn-ghost-success btn-sm"><i class="ti ti-device-floppy me-1"></i>Zapisz</button>
                        </form>
                        <a href="{{ path('app_dictation_gen_pdf') }}" class="btn btn-ghost-primary btn-sm" target="_blank"><i class="ti ti-file-type-pdf me-1"></i>PDF</a>
                        {% if data.type|default('classic') == 'classic' %}
                            <a href="{{ path('app_dictation_gen_pdf', {answers: 1}) }}" class="btn btn-ghost-primary btn-sm" target="_blank"><i class="ti ti-key me-1"></i>PDF+klucz</a>
                        {% endif %}
                    </div>
                </div>
                <div class="card-body">
                    {% if data.type|default('classic') == 'classic' %}
                        <div class="border rounded p-3 bg-light mb-3" style="font-family:Georgia,serif;line-height:2;font-size:.95rem;">
                            {{ data.text|nl2br }}
                        </div>

                        {% if data.difficultWords is defined and data.difficultWords|length > 0 %}
                            <h4 class="text-uppercase text-secondary small fw-bold mb-2"><i class="ti ti-alert-triangle me-1"></i>Trudne wyrazy ({{ data.difficultWords|length }})</h4>
                            <div class="table-responsive">
                                <table class="table table-sm table-bordered">
                                    <thead><tr><th>Wyraz</th><th>Reguła</th></tr></thead>
                                    <tbody>
                                        {% for w in data.difficultWords %}
                                            <tr>
                                                <td class="fw-bold">{{ w.word }}</td>
                                                <td class="text-secondary" style="font-size:.85rem;">{{ w.rule }}</td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% endif %}

                    {% elseif data.type|default('') == 'quiz' %}
                        {# Quiz dictation — simple A/B word choice #}
                        <div class="table-responsive">
                            <table class="table table-vcenter table-bordered mb-0">
                                <thead>
                                    <tr>
                                        <th style="width:40px;" class="text-center">Nr</th>
                                        <th class="text-center">A</th>
                                        <th class="text-center">B</th>
                                        <th style="width:50px;" class="text-center">Odp.</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for i, q in data.questions|default([]) %}
                                        <tr>
                                            <td class="text-center fw-bold">{{ i + 1 }}</td>
                                            {% for letter in ['A', 'B'] %}
                                                {% set opt = letter == 'A' ? q.optionA : q.optionB %}
                                                {% set isCorrect = q.correct == letter %}
                                                <td class="text-center {{ isCorrect ? 'bg-success-lt fw-bold' : '' }}" style="font-size:1rem;font-family:monospace;">
                                                    {{ opt }}
                                                    {% if isCorrect %} <i class="ti ti-check text-success"></i>{% endif %}
                                                </td>
                                            {% endfor %}
                                            <td class="text-center fw-bold text-primary">{{ q.correct }}</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>

                        {# Answer checker #}
                        {% set answerKey = {} %}
                        {% for i, q in data.questions|default([]) %}
                            {% set answerKey = answerKey|merge({(i + 1): q.correct}) %}
                        {% endfor %}
                        {% if answerKey|length > 0 %}
                            <div class="mt-3">
                                {% include 'generator/_answer_checker.html.twig' with {answerKey: answerKey, pointsPerQuestion: 1} %}
                            </div>
                        {% endif %}
                    {% endif %}
                </div>
            </div>
        {% else %}
            <div class="card border-0 bg-transparent shadow-none">
                <div class="card-body">
                    <div class="empty">
                        <div class="empty-icon"><i class="ti ti-writing-sign" style="font-size:3rem;"></i></div>
                        <p class="empty-title">Generator dyktand</p>
                        <p class="empty-subtitle text-secondary">Wybierz parametry i wygeneruj dyktando ortograficzne.<br>Klasyczne (tekst do czytania) lub testowe (pytania A/B z pisownią).</p>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
