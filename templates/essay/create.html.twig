{% extends 'base.html.twig' %}

{% block title %}Nowe zadanie — Nauczyciel Assistant{% endblock %}
{% block pretitle_text %}Wypracowania{% endblock %}
{% block title_text %}Nowe zadanie pisemne{% endblock %}

{% block page_actions %}
    <a href="{{ path('app_essay_index') }}" class="btn btn-outline-secondary btn-sm"><i class="ti ti-arrow-left me-1"></i>Lista zadań</a>
{% endblock %}

{% block body %}
<div class="row g-4">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header"><h3 class="card-title"><i class="ti ti-writing me-2"></i>Parametry zadania</h3></div>
            <div class="card-body">
                <form method="post" action="{{ path('app_essay_create') }}" data-turbo="false">
                    <div class="mb-3">
                        <label class="form-label required">Temat wypracowania</label>
                        <textarea name="topic" class="form-control" rows="2" required placeholder="np. Czy warto być odważnym? Rozważ problem, odwołując się do wybranej lektury."></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label required">Forma wypowiedzi</label>
                            <select name="writingForm" class="form-select" required>
                                {% for value, label in writingForms %}
                                    <option value="{{ value }}">{{ label }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label required">Klasa</label>
                            <select name="classLevel" class="form-select" required>
                                {% for cl in ['4','5','6','7','8'] %}
                                    <option value="{{ cl }}">Klasa {{ cl }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Min. słów</label>
                            <input type="number" name="minWords" class="form-control" placeholder="np. 200" min="0">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Dodatkowe wskazówki (widoczne dla ucznia)</label>
                        <textarea name="instructions" class="form-control" rows="3" placeholder="np. Odwołaj się do &quot;Kamieni na szaniec&quot;. Użyj min. 2 argumentów. Pamiętaj o wstępie i zakończeniu."></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Kryteria oceniania</label>
                            <select name="criteriaType" class="form-select">
                                <option value="cke">Kryteria CKE (egzamin 8-klasisty)</option>
                                <option value="custom">Ogólne (dostosowane do klasy)</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Termin oddania</label>
                            <input type="datetime-local" name="deadline" class="form-control">
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="ti ti-plus me-2"></i>Utwórz zadanie
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header"><h3 class="card-title"><i class="ti ti-info-circle me-2"></i>Jak to działa?</h3></div>
            <div class="card-body">
                <div class="steps steps-vertical">
                    <div class="step-item">
                        <div class="step-content">
                            <div class="step-title">Tworzysz zadanie</div>
                            <div class="text-secondary small">Podajesz temat, formę, klasę i termin</div>
                        </div>
                    </div>
                    <div class="step-item">
                        <div class="step-content">
                            <div class="step-title">Uczeń pisze pracę</div>
                            <div class="text-secondary small">Podajesz uczniom 6-znakowy kod — wpisują tekst online</div>
                        </div>
                    </div>
                    <div class="step-item">
                        <div class="step-content">
                            <div class="step-title">AI analizuje</div>
                            <div class="text-secondary small">Klikasz „Sprawdź AI" — system ocenia treść, język, ortografię</div>
                        </div>
                    </div>
                    <div class="step-item">
                        <div class="step-content">
                            <div class="step-title">Zatwierdzasz ocenę</div>
                            <div class="text-secondary small">Przeglądasz analizę, koregujesz punkty, dodajesz komentarz</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header"><h3 class="card-title"><i class="ti ti-scale me-2"></i>Kryteria CKE</h3></div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2"><span>Treść</span><strong>0–4 pkt</strong></div>
                <div class="d-flex justify-content-between mb-2"><span>Kompozycja</span><strong>0–3 pkt</strong></div>
                <div class="d-flex justify-content-between mb-2"><span>Język i styl</span><strong>0–3 pkt</strong></div>
                <div class="d-flex justify-content-between mb-2"><span>Ortografia</span><strong>0–2 pkt</strong></div>
                <div class="d-flex justify-content-between"><span>Interpunkcja</span><strong>0–2 pkt</strong></div>
                <hr>
                <div class="d-flex justify-content-between fw-bold"><span>Razem</span><span>14 pkt</span></div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
