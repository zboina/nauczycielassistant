{% extends 'base.html.twig' %}

{% block title %}Wypracowania — Nauczyciel Assistant{% endblock %}
{% block pretitle_text %}Wypracowania{% endblock %}
{% block title_text %}Sprawdzanie wypracowań{% endblock %}

{% block page_actions %}
    <a href="{{ path('app_essay_create') }}" class="btn btn-primary btn-sm">
        <i class="ti ti-plus me-1"></i>Nowe zadanie
    </a>
{% endblock %}

{% block body %}
{# Filters #}
<div class="d-flex gap-2 mb-3">
    <a href="{{ path('app_essay_index') }}" class="btn btn-sm {{ currentClass is null ? 'btn-primary' : 'btn-outline-primary' }}">Wszystkie</a>
    {% for cl in ['4','5','6','7','8'] %}
        <a href="{{ path('app_essay_index', {class: cl}) }}" class="btn btn-sm {{ currentClass == cl ? 'btn-primary' : 'btn-outline-primary' }}">Kl. {{ cl }}</a>
    {% endfor %}
</div>

{% if essays|length > 0 %}
<div x-data="essayTable()" x-init="init()">
    <div class="card mb-2">
        <div class="card-body py-2">
            <div class="row g-2 align-items-center">
                <div class="col">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text"><i class="ti ti-search"></i></span>
                        <input type="text" class="form-control" placeholder="Szukaj..." x-model="search" @input="filter()">
                        <button class="btn btn-outline-secondary" x-show="search" @click="search=''; filter()"><i class="ti ti-x"></i></button>
                    </div>
                </div>
                <div class="col-auto text-secondary small"><span x-text="filtered.length"></span> / {{ essays|length }}</div>
            </div>
        </div>
    </div>
    <div class="card">
        <div class="table-responsive">
            <table class="table table-vcenter card-table table-hover table-sm">
                <thead>
                    <tr>
                        <th style="cursor:pointer;" @click="sortBy('topic')">Temat</th>
                        <th style="width:55px;">Kl.</th>
                        <th style="width:70px;">Kod</th>
                        <th style="width:60px;">Prace</th>
                        <th style="width:60px;">Status</th>
                        <th style="width:100px;cursor:pointer;" @click="sortBy('date')">Data</th>
                        <th style="width:60px;" class="text-end">Akcje</th>
                    </tr>
                </thead>
                <tbody>
                    <template x-for="e in filtered" :key="e.id">
                        <tr>
                            <td>
                                <a :href="e.showUrl" class="text-reset fw-medium" x-text="e.topic"></a>
                                <div class="text-secondary" style="font-size:.72rem;" x-text="e.form"></div>
                            </td>
                            <td><span class="badge bg-primary-lt" x-text="e.cl"></span></td>
                            <td><code class="text-primary" x-text="e.code"></code></td>
                            <td>
                                <span class="badge bg-blue-lt" x-text="e.subs"></span>
                                <span class="badge bg-green-lt" x-text="e.reviewed" x-show="e.reviewed > 0"></span>
                            </td>
                            <td>
                                <span class="badge" :class="e.active ? 'bg-green-lt' : 'bg-secondary-lt'" x-text="e.active ? 'Aktywne' : 'Zamkn.'"></span>
                            </td>
                            <td class="text-secondary" style="font-size:.8rem;" x-text="e.date"></td>
                            <td class="text-end">
                                <a :href="e.showUrl" class="btn btn-ghost-primary btn-sm"><i class="ti ti-eye"></i></a>
                            </td>
                        </tr>
                    </template>
                </tbody>
            </table>
        </div>
        <div x-show="filtered.length===0 && search" class="card-body text-center text-secondary py-3">Brak wyników</div>
    </div>
</div>
<script>
function essayTable() {
    return {
        all:[], filtered:[], search:'', sf:'date', sd:'desc',
        init() {
            this.all = [{% for e in essays %}{
                id:{{e.id}}, topic:{{e.topic|json_encode|raw}}, cl:{{e.classLevel|json_encode|raw}},
                code:{{e.accessCode|json_encode|raw}}, form:{{e.writingFormLabel|json_encode|raw}},
                subs:{{e.submissionCount}}, reviewed:{{e.reviewedCount}}, active:{{e.isAccepting?'true':'false'}},
                date:{{e.createdAt|date('d.m.Y')|json_encode|raw}}, dateRaw:{{e.createdAt|date('U')}},
                showUrl:{{path('app_essay_show',{id:e.id})|json_encode|raw}}
            }{{not loop.last?',':''}}{% endfor %}];
            this.filter();
        },
        filter() { var s=this.search.toLowerCase(); this.filtered=this.all.filter(function(e){return !s||e.topic.toLowerCase().includes(s)||e.cl.includes(s)||e.code.toLowerCase().includes(s);}); this.doSort(); },
        sortBy(f) { if(this.sf===f) this.sd=this.sd==='asc'?'desc':'asc'; else{this.sf=f;this.sd=f==='date'?'desc':'asc';} this.doSort(); },
        doSort() { var f=this.sf,d=this.sd==='asc'?1:-1; this.filtered.sort(function(a,b){var va,vb;if(f==='topic'){va=a.topic.toLowerCase();vb=b.topic.toLowerCase();}else{va=a.dateRaw;vb=b.dateRaw;}return va<vb?-d:va>vb?d:0;}); }
    };
}
</script>
{% else %}
    <div class="card">
        <div class="card-body">
            <div class="empty">
                <div class="empty-icon"><i class="ti ti-writing" style="font-size:2.5rem;"></i></div>
                <p class="empty-title">Brak zadań</p>
                <div class="empty-action">
                    <a href="{{ path('app_essay_create') }}" class="btn btn-primary"><i class="ti ti-plus me-2"></i>Nowe zadanie</a>
                </div>
            </div>
        </div>
    </div>
{% endif %}
{% endblock %}
