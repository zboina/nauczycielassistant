{% extends 'base.html.twig' %}

{% block title %}Recenzja: {{ submission.studentName }} — Nauczyciel Assistant{% endblock %}
{% block pretitle_text %}Wypracowania{% endblock %}
{% block title_text %}Recenzja pracy: {{ submission.studentName }}{% endblock %}

{% block page_actions %}
    <a href="{{ path('app_essay_show', {id: essay.id}) }}" class="btn btn-outline-secondary btn-sm"><i class="ti ti-arrow-left me-1"></i>Wróć do zadania</a>
{% endblock %}

{% set ai = submission.aiAnalysis %}
{% set detect = submission.aiDetection %}

{% block body %}
<div class="row g-4">
    {# Left: student text + errors + detection #}
    <div class="col-lg-7">
        {# Student text #}
        <div class="card mb-3">
            <div class="card-header">
                <h3 class="card-title"><i class="ti ti-file-text me-2"></i>Praca ucznia</h3>
                <div class="card-actions">
                    <span class="badge bg-{{ submission.wordCount >= (essay.minWords ?? 0) ? 'green' : 'red' }}-lt">
                        {{ submission.wordCount }} słów
                        {% if essay.minWords %} / min. {{ essay.minWords }}{% endif %}
                    </span>
                </div>
            </div>
            <div class="card-body">
                <div class="border rounded p-3 bg-light mb-3">
                    <div class="fw-bold mb-1">Temat:</div>
                    <div>{{ essay.topic }}</div>
                </div>
                <div style="white-space:pre-wrap; line-height:2; font-family:Georgia,serif; font-size:.95rem;">{{ submission.content }}</div>
            </div>
        </div>

        {% if ai and ai.errors is defined and ai.errors|length > 0 %}
        {# Errors found by AI #}
        <div class="card mb-3">
            <div class="card-header">
                <h3 class="card-title"><i class="ti ti-alert-triangle me-2 text-warning"></i>Błędy znalezione przez AI ({{ ai.errors|length }})</h3>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-vcenter card-table">
                        <thead>
                            <tr>
                                <th style="width:100px;">Typ</th>
                                <th>Fragment</th>
                                <th>Poprawnie</th>
                                <th>Reguła</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% set errorColors = {'ortografia': 'red', 'interpunkcja': 'orange', 'styl': 'blue', 'gramatyka': 'purple'} %}
                            {% for error in ai.errors %}
                                <tr>
                                    <td><span class="badge bg-{{ errorColors[error.type] ?? 'secondary' }}-lt">{{ error.type }}</span></td>
                                    <td class="fw-medium text-danger" style="text-decoration:line-through;">{{ error.fragment }}</td>
                                    <td class="text-success fw-medium">{{ error.correction }}</td>
                                    <td style="font-size:.82rem;" class="text-secondary">{{ error.rule }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        {% endif %}

        {# ── AI Detection Panel ── #}
        {% if detect %}
            {% set verdictColors = {'autentyczne': 'green', 'prawdopodobnie autentyczne': 'blue', 'podejrzane': 'orange', 'prawdopodobnie AI': 'red'} %}
            {% set verdictColor = verdictColors[detect.verdict] ?? 'secondary' %}
            {% set score = detect.score ?? 0 %}
            <div class="card mb-3">
                <div class="card-status-start bg-{{ verdictColor }}"></div>
                <div class="card-header">
                    <h3 class="card-title"><i class="ti ti-robot me-2"></i>Detekcja AI-autorstwa</h3>
                    <div class="card-actions">
                        <span class="badge bg-{{ verdictColor }} fs-6">{{ detect.verdict|upper }}</span>
                    </div>
                </div>
                <div class="card-body">
                    {# Score gauge #}
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-success fw-medium" style="font-size:.8rem;">Ludzki tekst</span>
                            <span class="fw-bold">{{ score }}%</span>
                            <span class="text-danger fw-medium" style="font-size:.8rem;">Tekst AI</span>
                        </div>
                        <div class="progress" style="height:12px;">
                            <div class="progress-bar bg-{{ verdictColor }}" style="width:{{ score }}%"></div>
                        </div>
                    </div>

                    {# Summary #}
                    {% if detect.summary is defined %}
                        <div class="alert alert-{{ verdictColor }} mb-3" style="font-size:.88rem;">
                            <i class="ti ti-info-circle me-1"></i>{{ detect.summary }}
                        </div>
                    {% endif %}

                    {# Indicators #}
                    {% if detect.indicators is defined %}
                        <h4 class="text-uppercase text-secondary small fw-bold mb-2">Wskaźniki</h4>
                        {% for ind in detect.indicators %}
                            <div class="d-flex gap-2 mb-2 align-items-start">
                                {% if ind.detected %}
                                    <i class="ti ti-alert-circle text-{{ ind.weight == 'wysoka' ? 'danger' : 'warning' }} flex-shrink-0" style="margin-top:2px;"></i>
                                {% else %}
                                    <i class="ti ti-circle-check text-success flex-shrink-0" style="margin-top:2px;"></i>
                                {% endif %}
                                <div>
                                    <div class="fw-medium" style="font-size:.85rem;">
                                        {{ ind.name }}
                                        {% if ind.detected %}
                                            <span class="badge bg-{{ ind.weight == 'wysoka' ? 'red' : (ind.weight == 'średnia' ? 'orange' : 'yellow') }}-lt ms-1" style="font-size:.65rem;">{{ ind.weight }}</span>
                                        {% endif %}
                                    </div>
                                    <div class="text-secondary" style="font-size:.78rem;">{{ ind.explanation }}</div>
                                </div>
                            </div>
                        {% endfor %}
                    {% endif %}

                    {# Human vs AI signals #}
                    <div class="row g-3 mt-2">
                        {% if detect.humanSignals is defined and detect.humanSignals|length > 0 %}
                        <div class="col-md-6">
                            <div class="border rounded p-2 h-100 bg-green-lt">
                                <div class="fw-bold text-green small mb-1"><i class="ti ti-user me-1"></i>Sygnały ludzkie</div>
                                {% for s in detect.humanSignals %}
                                    <div class="d-flex gap-1 mb-1" style="font-size:.78rem;">
                                        <i class="ti ti-check text-green flex-shrink-0" style="margin-top:2px;"></i>
                                        <span>{{ s }}</span>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                        {% endif %}
                        {% if detect.aiSignals is defined and detect.aiSignals|length > 0 %}
                        <div class="col-md-6">
                            <div class="border rounded p-2 h-100 bg-red-lt">
                                <div class="fw-bold text-red small mb-1"><i class="ti ti-robot me-1"></i>Sygnały AI</div>
                                {% for s in detect.aiSignals %}
                                    <div class="d-flex gap-1 mb-1" style="font-size:.78rem;">
                                        <i class="ti ti-alert-triangle text-red flex-shrink-0" style="margin-top:2px;"></i>
                                        <span>{{ s }}</span>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                        {% endif %}
                    </div>

                    {# Recommendation #}
                    {% if detect.recommendation is defined %}
                        <div class="mt-3 p-2 border rounded bg-light" style="font-size:.85rem;">
                            <i class="ti ti-bulb text-primary me-1"></i><strong>Zalecenie:</strong> {{ detect.recommendation }}
                        </div>
                    {% endif %}
                </div>
            </div>
        {% else %}
            {# Detection not run yet — show button #}
            <div class="card mb-3">
                <div class="card-body d-flex align-items-center gap-3">
                    <span class="avatar avatar-lg rounded bg-red-lt"><i class="ti ti-robot" style="font-size:1.3rem;"></i></span>
                    <div class="flex-fill">
                        <h3 class="mb-1" style="font-size:.95rem;">Detekcja AI-autorstwa</h3>
                        <div class="text-secondary" style="font-size:.82rem;">Sprawdź, czy praca mogła być napisana przez ChatGPT / Gemini / inny generator</div>
                    </div>
                    <form method="post" action="{{ path('app_essay_ai_detect', {id: submission.id}) }}" data-ai-loading="Trwa analiza autentyczności tekstu...">
                        <button type="submit" class="btn btn-outline-red btn-sm">
                            <i class="ti ti-robot me-1"></i>Sprawdź
                        </button>
                    </form>
                </div>
            </div>
        {% endif %}
    </div>

    {# Right: AI analysis + teacher form #}
    <div class="col-lg-5">
        {% if ai %}
            {# AI Scores #}
            <div class="card mb-3">
                <div class="card-stamp"><div class="card-stamp-icon bg-purple"><i class="ti ti-sparkles"></i></div></div>
                <div class="card-header">
                    <h3 class="card-title"><i class="ti ti-sparkles me-2"></i>Analiza AI</h3>
                    <div class="card-actions">
                        {% if ai.suggestedGrade is defined %}
                            <span class="badge bg-blue fs-5">{{ ai.suggestedGrade }}</span>
                        {% endif %}
                    </div>
                </div>
                <div class="card-body">
                    {# Score bars #}
                    {% if ai.scores is defined %}
                        {% for score in ai.scores %}
                            {% set pct = score.max > 0 ? (score.score / score.max * 100) : 0 %}
                            {% set barColor = pct >= 75 ? 'green' : (pct >= 50 ? 'yellow' : (pct >= 25 ? 'orange' : 'red')) %}
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="fw-medium" style="font-size:.88rem;">{{ score.category }}</span>
                                    <strong class="text-{{ barColor }}">{{ score.score }}/{{ score.max }}</strong>
                                </div>
                                <div class="progress progress-sm">
                                    <div class="progress-bar bg-{{ barColor }}" style="width: {{ pct }}%"></div>
                                </div>
                                {% if score.justification is defined %}
                                    <div class="text-secondary mt-1" style="font-size:.78rem;">{{ score.justification }}</div>
                                {% endif %}
                            </div>
                        {% endfor %}
                        <hr>
                        <div class="d-flex justify-content-between fw-bold">
                            <span>Razem</span>
                            <span>{{ submission.totalAiScore }}/{{ submission.maxAiScore }} pkt</span>
                        </div>
                    {% endif %}
                </div>
            </div>

            {# Strengths & weaknesses #}
            <div class="row g-3 mb-3">
                {% if ai.strengths is defined and ai.strengths|length > 0 %}
                <div class="col-12">
                    <div class="card border-success">
                        <div class="card-header py-2">
                            <h3 class="card-title text-success" style="font-size:.9rem;"><i class="ti ti-thumb-up me-1"></i>Mocne strony</h3>
                        </div>
                        <div class="card-body py-2">
                            {% for s in ai.strengths %}
                                <div class="d-flex gap-2 mb-1">
                                    <i class="ti ti-check text-success flex-shrink-0" style="margin-top:3px;"></i>
                                    <span style="font-size:.85rem;">{{ s }}</span>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
                {% endif %}
                {% if ai.weaknesses is defined and ai.weaknesses|length > 0 %}
                <div class="col-12">
                    <div class="card border-warning">
                        <div class="card-header py-2">
                            <h3 class="card-title text-warning" style="font-size:.9rem;"><i class="ti ti-alert-triangle me-1"></i>Do poprawy</h3>
                        </div>
                        <div class="card-body py-2">
                            {% for w in ai.weaknesses %}
                                <div class="d-flex gap-2 mb-1">
                                    <i class="ti ti-arrow-right text-warning flex-shrink-0" style="margin-top:3px;"></i>
                                    <span style="font-size:.85rem;">{{ w }}</span>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
                {% endif %}
            </div>

            {# Feedback for student #}
            {% if ai.feedbackForStudent is defined %}
            <div class="card mb-3">
                <div class="card-header py-2">
                    <h3 class="card-title" style="font-size:.9rem;"><i class="ti ti-message-circle me-2"></i>Informacja zwrotna dla ucznia</h3>
                </div>
                <div class="card-body" style="font-size:.88rem;line-height:1.7;">{{ ai.feedbackForStudent }}</div>
            </div>
            {% endif %}

        {% else %}
            {# No AI analysis yet #}
            <div class="card mb-3">
                <div class="card-body text-center py-4">
                    <div class="mb-3"><i class="ti ti-sparkles text-secondary" style="font-size:2.5rem;"></i></div>
                    <h3>Brak analizy AI</h3>
                    <p class="text-secondary">Kliknij poniżej, aby AI przeanalizowało tę pracę.</p>
                    <form method="post" action="{{ path('app_essay_ai_review', {id: submission.id}) }}" data-ai-loading="Trwa analiza wypracowania...">
                        <button type="submit" class="btn btn-warning">
                            <i class="ti ti-sparkles me-1"></i>Sprawdź AI
                        </button>
                    </form>
                </div>
            </div>
        {% endif %}

        {# Teacher scoring form #}
        <div class="card">
            <div class="card-status-top bg-green"></div>
            <div class="card-header">
                <h3 class="card-title"><i class="ti ti-check me-2"></i>Ocena nauczyciela</h3>
            </div>
            <div class="card-body">
                <form method="post" action="{{ path('app_essay_review', {id: submission.id}) }}" data-turbo="false">
                    {% set categories = [
                        {key: 'tresc', label: 'Treść i realizacja tematu', max: 4},
                        {key: 'kompozycja', label: 'Kompozycja', max: 3},
                        {key: 'jezyk', label: 'Język i styl', max: 3},
                        {key: 'ortografia', label: 'Ortografia', max: 2},
                        {key: 'interpunkcja', label: 'Interpunkcja', max: 2},
                    ] %}

                    {% for cat in categories %}
                        {% set aiVal = null %}
                        {% if ai and ai.scores is defined %}
                            {% for s in ai.scores %}
                                {% if s.category starts with cat.label[:6] %}{% set aiVal = s.score %}{% endif %}
                            {% endfor %}
                        {% endif %}
                        {% set teacherVal = submission.teacherScores[cat.key] ?? aiVal %}
                        <div class="mb-3">
                            <label class="form-label d-flex justify-content-between">
                                <span>{{ cat.label }}</span>
                                <span class="text-secondary">max {{ cat.max }} pkt</span>
                            </label>
                            <div class="d-flex gap-1">
                                {% for i in range(0, cat.max) %}
                                    <label class="form-selectgroup-item flex-fill">
                                        <input type="radio" name="score[{{ cat.key }}]" value="{{ i }}" class="form-selectgroup-input"
                                               {{ teacherVal is same as(i) ? 'checked' : '' }}>
                                        <span class="form-selectgroup-label text-center">{{ i }}</span>
                                    </label>
                                {% endfor %}
                            </div>
                        </div>
                    {% endfor %}

                    <div class="mb-3">
                        <label class="form-label">Komentarz nauczyciela</label>
                        <textarea name="teacherComment" class="form-control" rows="4" placeholder="Opcjonalny komentarz do pracy...">{{ submission.teacherComment }}</textarea>
                    </div>

                    <button type="submit" class="btn btn-success w-100">
                        <i class="ti ti-check me-2"></i>Zatwierdź ocenę
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
