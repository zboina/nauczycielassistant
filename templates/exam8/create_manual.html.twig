{% extends 'base.html.twig' %}

{% block title %}Nowy arkusz — Nauczyciel Assistant{% endblock %}
{% block pretitle_text %}Egzamin 8-klasisty{% endblock %}
{% block title_text %}Utwórz arkusz ręcznie{% endblock %}

{% block page_actions %}
    <a href="{{ path('app_exam8_index') }}" class="btn btn-outline-secondary btn-sm"><i class="ti ti-arrow-left me-1"></i>Lista</a>
{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header"><h3 class="card-title"><i class="ti ti-plus me-2"></i>Nowy arkusz próbny</h3></div>
            <div class="card-body">
                <form method="post">
                    <div class="mb-3">
                        <label class="form-label required">Tytuł</label>
                        <input type="text" name="title" class="form-control" required autofocus placeholder="np. Arkusz próbny — marzec 2026">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Klasa</label>
                        <div class="d-flex gap-2">
                            {% for cl in ['7','8'] %}
                                <label class="form-selectgroup-item flex-fill">
                                    <input type="radio" name="classLevel" value="{{ cl }}" class="form-selectgroup-input" {{ cl == '8' ? 'checked' : '' }}>
                                    <span class="form-selectgroup-label text-center">Kl. {{ cl }}</span>
                                </label>
                            {% endfor %}
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="ti ti-plus me-2"></i>Utwórz i przejdź do edytora
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
