{% extends 'base.html.twig' %}

{% block title %}Egzamin 8-klasisty — Nauczyciel Assistant{% endblock %}
{% block pretitle_text %}Egzamin ósmoklasisty{% endblock %}
{% block title_text %}Arkusze próbne{% endblock %}

{% block page_actions %}
    <div class="btn-group">
        <a href="{{ path('app_exam8_generate') }}" class="btn btn-primary btn-sm"><i class="ti ti-sparkles me-1"></i>Generuj AI</a>
        <a href="{{ path('app_exam8_create_manual') }}" class="btn btn-outline-primary btn-sm"><i class="ti ti-plus me-1"></i>Nowy ręcznie</a>
    </div>
{% endblock %}

{% block body %}
{% if exams|length > 0 %}
<div x-data="examTable()" x-init="init()">
    <div class="card mb-2">
        <div class="card-body py-2">
            <div class="row g-2 align-items-center">
                <div class="col">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text"><i class="ti ti-search"></i></span>
                        <input type="text" class="form-control" placeholder="Szukaj..." x-model="search" @input="filter()">
                        <button class="btn btn-outline-secondary" x-show="search" @click="search=''; filter()"><i class="ti ti-x"></i></button>
                    </div>
                </div>
                <div class="col-auto text-secondary small"><span x-text="filtered.length"></span> / {{ exams|length }}</div>
            </div>
        </div>
    </div>
    <div class="card">
        <div class="table-responsive">
            <table class="table table-vcenter card-table table-hover table-sm">
                <thead>
                    <tr>
                        <th style="cursor:pointer;" @click="sortBy('title')">Tytuł</th>
                        <th style="width:55px;">Kl.</th>
                        <th style="width:55px;">Pkt</th>
                        <th style="width:70px;">Wyniki</th>
                        <th style="width:100px;cursor:pointer;" @click="sortBy('date')">Data</th>
                        <th style="width:150px;" class="text-end">Akcje</th>
                    </tr>
                </thead>
                <tbody>
                    <template x-for="e in filtered" :key="e.id">
                        <tr>
                            <td><a :href="e.showUrl" class="text-reset fw-medium" x-text="e.title"></a></td>
                            <td><span class="badge bg-primary-lt" x-text="e.cl"></span></td>
                            <td class="text-secondary" x-text="e.pts"></td>
                            <td>
                                <span class="badge bg-blue-lt" x-show="e.results > 0" x-text="e.results + ' (' + e.avg + '%)'"></span>
                            </td>
                            <td class="text-secondary" style="font-size:.8rem;" x-text="e.date"></td>
                            <td class="text-end text-nowrap">
                                <div class="btn-group">
                                    <a :href="e.showUrl" class="btn btn-ghost-primary btn-sm" title="Podgląd"><i class="ti ti-eye"></i></a>
                                    <a :href="e.editUrl" class="btn btn-ghost-blue btn-sm" title="Edytuj"><i class="ti ti-edit"></i></a>
                                    <a :href="e.resultsUrl" class="btn btn-ghost-green btn-sm" title="Wyniki"><i class="ti ti-chart-bar"></i></a>
                                    <a :href="e.pdfUrl" class="btn btn-ghost-primary btn-sm" target="_blank" title="PDF"><i class="ti ti-file-type-pdf"></i></a>
                                </div>
                            </td>
                        </tr>
                    </template>
                </tbody>
            </table>
        </div>
        <div x-show="filtered.length===0 && search" class="card-body text-center text-secondary py-3">Brak wyników</div>
    </div>
</div>
<script>
function examTable() {
    return {
        all:[], filtered:[], search:'', sf:'date', sd:'desc',
        init() {
            this.all = [{% for e in exams %}{
                id:{{e.id}}, title:{{e.title|json_encode|raw}}, cl:{{e.classLevel|json_encode|raw}},
                pts:{{e.maxPoints}}, results:{{e.resultCount}}, avg:{{e.averagePercent ?? 0}},
                date:{{e.createdAt|date('d.m.Y')|json_encode|raw}}, dateRaw:{{e.createdAt|date('U')}},
                showUrl:{{path('app_exam8_show',{id:e.id})|json_encode|raw}},
                editUrl:{{path('app_exam8_edit',{id:e.id})|json_encode|raw}},
                resultsUrl:{{path('app_exam8_results',{id:e.id})|json_encode|raw}},
                pdfUrl:{{path('app_exam8_pdf',{id:e.id})|json_encode|raw}}
            }{{not loop.last?',':''}}{% endfor %}];
            this.filter();
        },
        filter() { var s=this.search.toLowerCase(); this.filtered=this.all.filter(function(e){return !s||e.title.toLowerCase().includes(s)||e.cl.includes(s);}); this.doSort(); },
        sortBy(f) { if(this.sf===f) this.sd=this.sd==='asc'?'desc':'asc'; else{this.sf=f;this.sd=f==='date'?'desc':'asc';} this.doSort(); },
        doSort() { var f=this.sf,d=this.sd==='asc'?1:-1; this.filtered.sort(function(a,b){var va,vb;if(f==='title'){va=a.title.toLowerCase();vb=b.title.toLowerCase();}else{va=a.dateRaw;vb=b.dateRaw;}return va<vb?-d:va>vb?d:0;}); }
    };
}
</script>
{% else %}
    <div class="card">
        <div class="card-body">
            <div class="empty">
                <div class="empty-icon"><i class="ti ti-school" style="font-size:2.5rem;"></i></div>
                <p class="empty-title">Brak arkuszy próbnych</p>
                <div class="empty-action">
                    <a href="{{ path('app_exam8_generate') }}" class="btn btn-primary"><i class="ti ti-sparkles me-2"></i>Generuj arkusz</a>
                </div>
            </div>
        </div>
    </div>
{% endif %}
{% endblock %}
