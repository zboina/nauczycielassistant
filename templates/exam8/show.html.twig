{% extends 'base.html.twig' %}

{% block title %}{{ exam.title }} — Nauczyciel Assistant{% endblock %}
{% block pretitle_text %}Egzamin ósmoklasisty{% endblock %}
{% block title_text %}{{ exam.title }}{% endblock %}

{% block page_actions %}
    <a href="{{ path('app_exam8_index') }}" class="btn btn-outline-secondary btn-sm"><i class="ti ti-arrow-left me-1"></i>Lista</a>
{% endblock %}

{% block body %}
<div class="row g-4">
    <div class="col-lg-8">
        {% if data %}
            {# Parts (reading texts + questions) #}
            {% for part in data.parts ?? [] %}
                <div class="card mb-3">
                    <div class="card-status-start {{ loop.index == 1 ? 'bg-blue' : 'bg-green' }}"></div>
                    <div class="card-header">
                        <h3 class="card-title">{{ part.name }}</h3>
                        {% if part.textAuthor is defined %}
                            <div class="card-actions"><span class="text-secondary small">{{ part.textAuthor }}</span></div>
                        {% endif %}
                    </div>

                    {# Text fragment #}
                    {% if part.text is defined %}
                        <div class="card-body border-bottom">
                            <div class="p-3 border rounded bg-light" style="font-family:Georgia,serif;line-height:1.9;font-size:.92rem;font-style:italic;">
                                {{ part.text }}
                            </div>
                        </div>
                    {% endif %}

                    {# Questions #}
                    <div class="card-body">
                        {% for q in part.questions ?? [] %}
                            <div class="border rounded p-3 mb-2 {{ not loop.last ? '' : '' }}">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="fw-bold">Zadanie {{ q.number }}.</span>
                                    <div class="d-flex gap-2">
                                        {% if q.skill is defined %}
                                            <span class="badge bg-secondary-lt" style="font-size:.7rem;">{{ q.skill }}</span>
                                        {% endif %}
                                        <span class="badge {{ q.type == 'closed' ? 'bg-blue-lt' : 'bg-green-lt' }}">
                                            {{ q.type == 'closed' ? 'ABCD' : 'Otwarte' }} · {{ q.points }} pkt
                                        </span>
                                    </div>
                                </div>
                                <div class="mb-2">{{ q.text }}</div>

                                {% if q.type == 'closed' and q.options is defined %}
                                    {% set letters = ['A','B','C','D'] %}
                                    <div class="row g-2">
                                        {% for opt in q.options %}
                                            {% set letter = opt|split(')')|first|trim %}
                                            {% set isCorrect = q.correct is defined and (letters[loop.index0] == q.correct or letter == q.correct) %}
                                            <div class="col-6">
                                                <div class="d-flex align-items-center gap-2 p-2 border rounded {{ isCorrect ? 'border-success bg-success-lt' : '' }}">
                                                    <span class="avatar avatar-xs rounded fw-bold {{ isCorrect ? 'bg-success text-white' : 'bg-primary-lt' }}" style="font-size:.7rem;">{{ letters[loop.index0] }}</span>
                                                    <span style="font-size:.88rem;">{{ opt|split(') ')|last }}</span>
                                                    {% if isCorrect %}<i class="ti ti-check ms-auto text-success"></i>{% endif %}
                                                </div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% elseif q.answer is defined %}
                                    <div class="alert alert-success mb-0 mt-2" style="font-size:.85rem;">
                                        <i class="ti ti-key me-1"></i><strong>Model odpowiedzi:</strong> {{ q.answer }}
                                    </div>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endfor %}

            {# Essay topics #}
            {% if data.essayTopics is defined %}
                <div class="card mb-3">
                    <div class="card-status-start bg-orange"></div>
                    <div class="card-header">
                        <h3 class="card-title">Część 3 — Wypracowanie</h3>
                        <div class="card-actions"><span class="badge bg-orange-lt">{{ data.essayMaxPoints ?? 20 }} pkt</span></div>
                    </div>
                    <div class="card-body">
                        <p class="text-secondary mb-3">Wybierz <strong>jeden</strong> z poniższych tematów i napisz wypracowanie (min. {{ data.essayTopics[0].minWords ?? 200 }} słów).</p>
                        {% for topic in data.essayTopics %}
                            <div class="border rounded p-3 mb-2">
                                <div class="d-flex gap-2 mb-1">
                                    <span class="badge bg-{{ topic.type == 'rozprawka' ? 'blue' : 'green' }}-lt">{{ topic.type|capitalize }}</span>
                                    <span class="badge bg-secondary-lt">Temat {{ loop.index }}</span>
                                </div>
                                <div style="font-size:.95rem;">{{ topic.topic }}</div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        {% endif %}
    </div>

    {# Right sidebar #}
    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header"><h3 class="card-title">Informacje</h3></div>
            <div class="card-body">
                <div class="datagrid">
                    <div class="datagrid-item">
                        <div class="datagrid-title">Klasa</div>
                        <div class="datagrid-content"><span class="badge bg-primary-lt">{{ exam.classLevel }}</span></div>
                    </div>
                    <div class="datagrid-item">
                        <div class="datagrid-title">Typ</div>
                        <div class="datagrid-content">{{ exam.examTypeLabel }}</div>
                    </div>
                    <div class="datagrid-item">
                        <div class="datagrid-title">Maks. punktów</div>
                        <div class="datagrid-content"><strong>{{ exam.maxPoints }}</strong></div>
                    </div>
                    <div class="datagrid-item">
                        <div class="datagrid-title">Data</div>
                        <div class="datagrid-content">{{ exam.createdAt|date('d.m.Y') }}</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header"><h3 class="card-title">Pobierz PDF</h3></div>
            <div class="card-body d-flex flex-column gap-2">
                <a href="{{ path('app_exam8_pdf', {id: exam.id}) }}" class="btn btn-primary" target="_blank">
                    <i class="ti ti-file-type-pdf me-2"></i>PDF (uczeń)
                </a>
                <a href="{{ path('app_exam8_pdf', {id: exam.id, answers: 1}) }}" class="btn btn-outline-primary" target="_blank">
                    <i class="ti ti-file-type-pdf me-2"></i>PDF + klucz odpowiedzi
                </a>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header"><h3 class="card-title">Wyniki</h3></div>
            <div class="card-body d-flex flex-column gap-2">
                <a href="{{ path('app_exam8_results', {id: exam.id}) }}" class="btn btn-outline-blue">
                    <i class="ti ti-edit me-2"></i>Wprowadź wyniki
                </a>
                {% if exam.resultCount > 0 %}
                    <a href="{{ path('app_exam8_analysis', {id: exam.id}) }}" class="btn btn-outline-green">
                        <i class="ti ti-chart-bar me-2"></i>Analiza ({{ exam.resultCount }} wyników)
                    </a>
                {% endif %}
            </div>
        </div>

        <div class="card">
            <div class="card-body d-flex flex-column gap-2">
                <a href="{{ path('app_exam8_generate') }}" class="btn btn-outline-primary">
                    <i class="ti ti-sparkles me-1"></i>Generuj nowy arkusz
                </a>
                <form method="post" action="{{ path('app_exam8_delete', {id: exam.id}) }}" onsubmit="return confirm('Usunąć arkusz i wyniki?')">
                    <button type="submit" class="btn btn-outline-danger w-100"><i class="ti ti-trash me-1"></i>Usuń</button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
