{# Shared layout for all generators #}
{% extends 'base.html.twig' %}

{% block pretitle_text %}Generatory AI{% endblock %}

{% block page_actions %}
    {% block back_button %}
        <a href="{{ path('app_generate_history') }}" class="btn btn-outline-secondary btn-sm">
            <i class="ti ti-arrow-left me-1"></i>Lista
        </a>
    {% endblock %}
{% endblock %}

{% block body %}
<div class="row g-4">
    {# Left — form #}
    <div class="col-lg-5 col-xl-4">
        <div class="card sticky-top" style="top: 1rem;">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="ti ti-adjustments me-2"></i>{% block form_title %}Parametry{% endblock %}
                </h3>
            </div>
            <div class="card-body">
                {% block form_content %}{% endblock %}
            </div>
        </div>
    </div>

    {# Right — results #}
    <div class="col-lg-7 col-xl-8">
        {% block results_content %}{% endblock %}
    </div>
</div>
{% endblock %}
