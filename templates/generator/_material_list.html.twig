{# Reusable material list for generator index pages #}
{# Required vars: materials, typeLabel, typeIcon, typeColor, generateRoute, showRoute, pdfRoute #}

{% if materials|length > 0 %}
    <div class="row row-cards">
        {% for m in materials %}
            <div class="col-md-6 col-xl-4">
                <div class="card">
                    {% if m.isFavorite %}
                        <div class="card-status-start bg-yellow"></div>
                    {% endif %}
                    <div class="card-body">
                        <div class="d-flex align-items-start">
                            <div class="flex-fill">
                                <h3 class="card-title mb-1">
                                    <a href="{{ path(showRoute, {id: m.id}) }}" class="text-reset">
                                        {{ m.title ?? m.subjectContext|u.truncate(50) }}
                                    </a>
                                </h3>
                                {% if m.subjectContext and m.subjectContext != m.title %}
                                    <div class="text-secondary small">{{ m.subjectContext|u.truncate(60) }}</div>
                                {% endif %}
                            </div>
                            {% if m.isFavorite %}
                                <span class="text-yellow ms-2"><i class="ti ti-star-filled"></i></span>
                            {% endif %}
                        </div>
                        <div class="mt-3 d-flex gap-2 flex-wrap">
                            {% if m.classLevel %}
                                <span class="badge bg-primary-lt">Kl. {{ m.classLevel }}</span>
                            {% endif %}
                            <span class="badge bg-secondary-lt">{{ m.createdAt|date('d.m.Y H:i') }}</span>
                        </div>
                    </div>
                    <div class="card-footer d-flex justify-content-between">
                        <a href="{{ path(showRoute, {id: m.id}) }}" class="btn btn-primary btn-sm">
                            <i class="ti ti-eye me-1"></i>Podgląd
                        </a>
                        <div class="btn-group">
                            <a href="{{ path(pdfRoute, {id: m.id}) }}" class="btn btn-ghost-primary btn-sm" target="_blank" title="PDF">
                                <i class="ti ti-file-type-pdf"></i>
                            </a>
                            {% if m.type != 'parent_info' %}
                                <a href="{{ path('app_generate_history_docx', {id: m.id}) }}" class="btn btn-ghost-blue btn-sm" title="DOCX">
                                    <i class="ti ti-file-type-doc"></i>
                                </a>
                            {% endif %}
                            <form method="post" action="{{ path('app_generate_material_delete', {id: m.id}) }}" class="d-inline" onsubmit="return confirm('Usunąć?')">
                                <button class="btn btn-ghost-danger btn-sm"><i class="ti ti-trash"></i></button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% else %}
    <div class="card">
        <div class="card-body">
            <div class="empty">
                <div class="empty-icon"><i class="ti {{ typeIcon }}" style="font-size:2.5rem;"></i></div>
                <p class="empty-title">Brak zapisanych materiałów</p>
                <p class="empty-subtitle text-secondary">Wygeneruj pierwszy materiał, aby zobaczyć go tutaj.</p>
                <div class="empty-action">
                    <a href="{{ path(generateRoute) }}" class="btn btn-primary"><i class="ti ti-sparkles me-2"></i>Generuj {{ typeLabel }}</a>
                </div>
            </div>
        </div>
    </div>
{% endif %}
