{% extends 'base.html.twig' %}

{% block title %}Edycja dyktanda — Nauczyciel Assistant{% endblock %}
{% block pretitle_text %}Dyktanda{% endblock %}
{% block title_text %}Edycja dyktanda{% endblock %}

{% block page_actions %}
    <a href="{{ path('app_generate_history_show', {id: material.id}) }}" class="btn btn-outline-secondary btn-sm"><i class="ti ti-arrow-left me-1"></i>Podgląd</a>
{% endblock %}

{% block stylesheets %}
<style>
    .edit-field { border: 1px dashed transparent; padding: 2px 4px; border-radius: 4px; min-height: 1.5em; cursor: text; }
    .edit-field:hover { border-color: #ccc; }
    .edit-field:focus { border-color: var(--tblr-primary); outline: none; background: #fefef0; }
    .q-block { border: 1px solid #e6e8eb; border-radius: .5rem; padding: .75rem; margin-bottom: .5rem; position: relative; }
    .q-block:hover { box-shadow: 0 0 0 2px rgba(var(--tblr-primary-rgb),.15); }
    .q-block.dragging { opacity: .4; }
    .saved-toast { position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 9999; }
</style>
{% endblock %}

{% block body %}
<div x-data="dictEditor()" x-init="init()">
    {# Toolbar #}
    <div class="card mb-3">
        <div class="card-body py-2 d-flex align-items-center gap-3 flex-wrap">
            <span class="fw-bold edit-field flex-fill" contenteditable="true" @blur="d.title = $el.innerText" x-text="d.title"></span>
            <span class="badge bg-orange-lt" x-text="d.type === 'quiz' ? 'Testowe' : 'Klasyczne'"></span>
            <button class="btn btn-success btn-sm" @click="save()" :disabled="saving">
                <template x-if="!saving"><span><i class="ti ti-device-floppy me-1"></i>Zapisz</span></template>
                <template x-if="saving"><span><i class="ti ti-loader ti-spin me-1"></i>Zapisuję...</span></template>
            </button>
        </div>
    </div>

    {# Classic dictation editor #}
    <template x-if="d.type === 'classic' || !d.type">
        <div>
            <div class="card mb-3">
                <div class="card-header py-2"><h3 class="card-title" style="font-size:.9rem;"><i class="ti ti-file-text me-2"></i>Tekst dyktanda</h3></div>
                <div class="card-body">
                    <textarea class="form-control" rows="10" x-model="d.text" style="font-family:Georgia,serif;line-height:2;font-size:.95rem;"></textarea>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header py-2">
                    <h3 class="card-title" style="font-size:.9rem;"><i class="ti ti-alert-triangle me-2"></i>Trudne wyrazy</h3>
                    <div class="card-actions"><span class="badge bg-secondary-lt" x-text="(d.difficultWords||[]).length + ' wyrazów'"></span></div>
                </div>
                <div class="card-body">
                    <template x-for="(w, i) in d.difficultWords || []" :key="i">
                        <div class="d-flex gap-2 mb-2 align-items-start">
                            <input type="text" class="form-control form-control-sm" style="width:140px;font-weight:bold;" x-model="w.word" placeholder="Wyraz">
                            <input type="text" class="form-control form-control-sm flex-fill" x-model="w.rule" placeholder="Reguła ortograficzna">
                            <button class="btn btn-ghost-danger btn-sm flex-shrink-0" @click="d.difficultWords.splice(i,1)"><i class="ti ti-x"></i></button>
                        </div>
                    </template>
                    <button class="btn btn-outline-primary btn-sm" @click="(d.difficultWords = d.difficultWords||[]).push({word:'', rule:''})">
                        <i class="ti ti-plus me-1"></i>Dodaj wyraz
                    </button>
                </div>
            </div>
        </div>
    </template>

    {# Quiz dictation editor #}
    <template x-if="d.type === 'quiz'">
        <div>
            <template x-for="(q, i) in d.questions || []" :key="i">
                <div class="q-block" draggable="true"
                     @dragstart="dragIdx=i; $el.classList.add('dragging')" @dragend="dragIdx=null; $el.classList.remove('dragging')"
                     @dragover.prevent @drop="onDrop(i)">
                    <div class="d-flex gap-2 align-items-start mb-2">
                        <span class="badge bg-orange-lt" x-text="(i+1) + '.'"></span>
                        <input type="text" class="form-control form-control-sm flex-fill" x-model="q.display" placeholder="np. g_ra (ó czy u?)">
                        <button class="btn btn-ghost-danger btn-sm flex-shrink-0" @click="d.questions.splice(i,1)"><i class="ti ti-trash"></i></button>
                    </div>
                    <div class="row g-2">
                        <div class="col-5">
                            <div class="input-group input-group-sm">
                                <span class="badge" style="cursor:pointer;width:28px;line-height:28px;" :class="q.correct==='A' ? 'bg-green' : 'bg-secondary-lt'" @click="q.correct='A'">A</span>
                                <input type="text" class="form-control" x-model="q.optionA" placeholder="Opcja A">
                            </div>
                        </div>
                        <div class="col-5">
                            <div class="input-group input-group-sm">
                                <span class="badge" style="cursor:pointer;width:28px;line-height:28px;" :class="q.correct==='B' ? 'bg-green' : 'bg-secondary-lt'" @click="q.correct='B'">B</span>
                                <input type="text" class="form-control" x-model="q.optionB" placeholder="Opcja B">
                            </div>
                        </div>
                        <div class="col-2">
                            <input type="text" class="form-control form-control-sm" x-model="q.rule" placeholder="Reguła" style="font-size:.75rem;">
                        </div>
                    </div>
                </div>
            </template>

            <button class="btn btn-outline-orange w-100" @click="(d.questions = d.questions||[]).push({display:'', optionA:'', optionB:'', correct:'A', rule:''})">
                <i class="ti ti-plus me-1"></i>Dodaj pytanie
            </button>
        </div>
    </template>

    <div class="saved-toast" x-show="showSaved" x-transition.opacity>
        <div class="alert alert-success py-2 px-3 shadow"><i class="ti ti-check me-1"></i>Zapisano!</div>
    </div>
</div>

<script>
function dictEditor() {
    return {
        d: {}, saving: false, showSaved: false, dragIdx: null,

        init() {
            this.d = {{ data|json_encode|raw }};
            if (!this.d.difficultWords) this.d.difficultWords = [];
            if (!this.d.questions) this.d.questions = [];
        },

        onDrop(idx) {
            if (this.dragIdx === null || this.dragIdx === idx) return;
            var q = this.d.questions.splice(this.dragIdx, 1)[0];
            this.d.questions.splice(idx, 0, q);
            this.dragIdx = null;
        },

        async save() {
            this.saving = true;
            try {
                var r = await fetch('{{ path("app_generate_history_api_save", {id: material.id}) }}', {
                    method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(this.d)
                });
                var data = await r.json();
                if (data.ok) { this.showSaved = true; setTimeout(() => this.showSaved = false, 2000); }
                else alert(data.error);
            } catch(e) { alert(e.message); }
            finally { this.saving = false; }
        }
    };
}
</script>
{% endblock %}
