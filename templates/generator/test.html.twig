{% extends 'generator/_layout.html.twig' %}

{% block title %}Generator sprawdzianów — Nauczyciel Assistant{% endblock %}
{% block title_text %}Generator sprawdzianów i testów{% endblock %}
{% block form_title %}Parametry sprawdzianu{% endblock %}
{% block back_button %}<a href="{{ path('app_generate_test_index') }}" class="btn btn-outline-secondary btn-sm"><i class="ti ti-arrow-left me-1"></i>Sprawdziany</a>{% endblock %}

{% block form_content %}
<div x-data="testFormApp()">
    {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'data-ai-loading': 'Trwa generowanie sprawdzianu...'}}) }}

    <div class="mb-3">
        {{ form_label(form.classLevel) }}
        {{ form_widget(form.classLevel, {'attr': {'class': 'form-control', 'x-model': 'classInput', '@input': 'onClassChange()'}}) }}
        {{ form_errors(form.classLevel) }}
        {# Quick class buttons #}
        <div class="d-flex gap-1 mt-2 flex-wrap">
            <button type="button" class="btn btn-sm btn-outline-primary" @click="setClass('4')">Kl. 4</button>
            <button type="button" class="btn btn-sm btn-outline-primary" @click="setClass('5')">Kl. 5</button>
            <button type="button" class="btn btn-sm btn-outline-primary" @click="setClass('6')">Kl. 6</button>
            <button type="button" class="btn btn-sm btn-outline-primary" @click="setClass('7')">Kl. 7</button>
            <button type="button" class="btn btn-sm btn-outline-primary" @click="setClass('8')">Kl. 8</button>
        </div>
    </div>

    <div class="mb-3">
        {{ form_label(form.subject) }}
        {{ form_widget(form.subject, {'attr': {'class': 'form-control', 'x-ref': 'subjectInput'}}) }}
        {{ form_errors(form.subject) }}
    </div>

    {# Topic suggestions #}
    <div x-show="suggestions.length > 0" x-transition class="mb-3">
        <label class="form-label text-primary">
            <i class="ti ti-bulb me-1"></i>Propozycje tematów (PP MEN)
        </label>
        <div class="d-flex flex-wrap gap-1">
            <template x-for="(topic, i) in suggestions" :key="i">
                <button type="button"
                        class="btn btn-sm btn-outline-secondary text-start"
                        style="font-size:.78rem;"
                        @click="pickTopic(topic)"
                        x-text="topic">
                </button>
            </template>
        </div>
    </div>

    <div class="mb-3">
        {{ form_label(form.questionTypes) }}
        <div class="d-flex gap-3 flex-wrap">
            {% for child in form.questionTypes %}
                <label class="form-check">
                    {{ form_widget(child, {'attr': {'class': 'form-check-input'}}) }}
                    <span class="form-check-label">{{ child.vars.label }}</span>
                </label>
            {% endfor %}
        </div>
        {{ form_errors(form.questionTypes) }}
    </div>

    <div class="row">
        <div class="col-6 mb-3">
            {{ form_label(form.questionCount) }}
            {{ form_widget(form.questionCount, {'attr': {'class': 'form-select'}}) }}
        </div>
        <div class="col-6 mb-3">
            {{ form_label(form.difficulty) }}
            {{ form_widget(form.difficulty, {'attr': {'class': 'form-select'}}) }}
        </div>
    </div>

    <div class="mb-3">
        {{ form_label(form.notes) }}
        {{ form_widget(form.notes, {'attr': {'class': 'form-control'}}) }}
    </div>

    <button type="submit" class="btn btn-primary w-100">
        <i class="ti ti-sparkles me-2"></i> Generuj sprawdzian
    </button>

    {{ form_end(form) }}
</div>

<script>
function testFormApp() {
    const topicsByClass = {
        '4': [
            // Lektury kl. IV
            '"W pustyni i w puszczy" — Przygody Stasia i Nel',
            '"W pustyni i w puszczy" — Odwaga i zaradność bohaterów',
            '"Akademia Pana Kleksa" — Świat fantazji a rzeczywistość',
            '"Akademia Pana Kleksa" — Pan Kleks jako niezwykły nauczyciel',
            'Baśnie — cechy gatunku i morał',
            'Legendy polskie — bohaterowie i przesłanie',
            // Mity i Biblia
            'Mity greckie — bogowie i ich atrybuty',
            'Biblia — stworzenie świata, potop',
            // Kształcenie językowe kl. IV
            'Części mowy — rozpoznawanie (rzeczownik, przymiotnik, czasownik)',
            'Rzeczownik — rodzaj, liczba, przypadek',
            'Czasownik — czas przeszły, teraźniejszy, przyszły',
            'Zdanie oznajmujące, pytające, rozkazujące',
            'Ortografia — pisownia ó/u',
            'Ortografia — pisownia rz/ż',
            // Formy wypowiedzi
            'Opowiadanie — budowa (wstęp, rozwinięcie, zakończenie)',
            'Opis przedmiotu i krajobrazu',
            'Życzenia, zaproszenie, ogłoszenie',
        ],
        '5': [
            // Lektury kl. V
            '"Opowieści z Narnii: Lew, czarownica i stara szafa" — Dobro i zło w krainie Narnii',
            '"Opowieści z Narnii" — Aslan jako symbol dobra',
            '"Hobbit" — Bilbo Baggins jako bohater, który się zmienia',
            '"Hobbit" — Motyw podróży i przygody',
            '"Chłopcy z Placu Broni" — Honor i lojalność',
            '"Chłopcy z Placu Broni" — Nemecsek jako bohater tragiczny',
            'Baśnie H.Ch. Andersena — przesłanie i symbolika',
            // Mity
            'Mity greckie — podróże Odyseusza',
            'Mity greckie — postacie i ich symbolika',
            // Kształcenie językowe kl. V
            'Przymiotnik — stopniowanie regularne i nieregularne',
            'Przysłówek — rozpoznawanie i funkcja',
            'Zdanie pojedyncze — podmiot i orzeczenie',
            'Zdanie pojedyncze rozwinięte i nierozwinięte',
            'Ortografia — pisownia ch/h',
            'Wielka i mała litera — zasady',
            // Formy wypowiedzi
            'List prywatny — zasady pisania',
            'Opis postaci — wygląd i charakter',
            'Sprawozdanie z wycieczki lub wydarzenia',
        ],
        '6': [
            // Lektury kl. IV-VI
            '"Hobbit" — Bilbo Baggins jako bohater, który się zmienia',
            '"Hobbit" — Motyw podróży i przygody',
            '"Chłopcy z Placu Broni" — Honor i lojalność',
            '"Chłopcy z Placu Broni" — Nemecsek jako prawdziwy bohater',
            '"Opowieści z Narnii" — Dobro i zło w świecie fantasy',
            '"Akademia Pana Kleksa" — Świat fantastyczny a rzeczywisty',
            // Mity i Biblia
            'Mity greckie — postacie i ich symbolika',
            'Biblia — przypowieść o miłosiernym Samarytaninie',
            // Kształcenie językowe kl. IV-VI
            'Części mowy — rozpoznawanie i funkcje w tekście',
            'Rzeczownik, przymiotnik, czasownik — odmiana',
            'Zdanie pojedyncze i złożone',
            'Figury stylistyczne: epitet, porównanie, przenośnia',
            'Ortografia — pisownia ó/u, rz/ż, ch/h',
            'Interpunkcja — przecinek w zdaniu złożonym',
            // Formy wypowiedzi
            'Opowiadanie twórcze — budowa i elementy',
            'Opis postaci — charakterystyka bohatera literackiego',
            'List — zasady pisania i formy grzecznościowe',
        ],
        '7': [
            // Lektury kl. VII-VIII
            '"Mały Książę" — Czym jest oswajanie i odpowiedzialność?',
            '"Mały Książę" — Świat dorosłych vs. świat dzieci',
            '"Zemsta" A. Fredry — Komizm i konflikty szlacheckie',
            '"Zemsta" — Papkin jako postać komiczna',
            '"Kamienie na szaniec" — Bohaterstwo młodych w czasie okupacji',
            '"Kamienie na szaniec" — Akcja pod Arsenałem',
            '"Opowieść wigilijna" — Przemiana Scrooge\'a',
            '"Dziady" cz. II — Obrzęd dziadów i świat duchów',
            // Mickiewicz
            '"Świtezianka" — Ballada romantyczna',
            '"Pan Tadeusz" — Opis przyrody i obyczajów szlacheckich',
            // Kształcenie językowe kl. VII-VIII
            'Rodzaje literackie: epika, liryka, dramat',
            'Środki stylistyczne: symbol, alegoria, ironia',
            'Style funkcjonalne języka (potoczny, urzędowy, artystyczny)',
            'Wyraz podstawowy i pochodny — słowotwórstwo',
            // Formy wypowiedzi
            'Rozprawka — budowa, teza, argumenty',
            'Recenzja książki lub filmu',
            'Charakterystyka porównawcza bohaterów',
        ],
        '8': [
            // Lektury kl. VIII
            '"Balladyna" — Zbrodnia i kara, droga do władzy',
            '"Balladyna" — Symbolika maliny i pioruna',
            '"Kamienie na szaniec" — Szare Szeregi i mały sabotaż',
            '"Dziady" cz. II — Romantyczna wizja świata',
            // Sienkiewicz, Żeromski
            '"Latarnik" — Tęsknota za ojczyzną',
            '"Quo vadis" (fragmenty) — Starożytny Rzym i chrześcijaństwo',
            '"Syzyfowe prace" (fragmenty) — Walka o polskość',
            // Poezja
            'Treny VII i VIII Kochanowskiego — Żal po stracie',
            'Fraszki Kochanowskiego — Mądrość i humor',
            '"Reduta Ordona" — Bohaterstwo i poświęcenie',
            'Poezja Szymborskiej, Herberta lub Różewicza',
            // Kształcenie językowe
            'Imiesłowy i równoważniki zdań',
            'Wypowiedzenia wielokrotnie złożone',
            'Mowa zależna i niezależna',
            'Manipulacja językowa — rozpoznawanie i obrona',
            // Formy wypowiedzi — egzamin 8-klasisty
            'Rozprawka — przygotowanie do egzaminu ósmoklasisty',
            'Streszczenie tekstu literackiego i popularnonaukowego',
        ],
    };

    return {
        classInput: '',
        suggestions: [],

        onClassChange() {
            const num = this.classInput.replace(/\D/g, '');
            this.suggestions = topicsByClass[num] || [];
        },

        setClass(n) {
            this.classInput = n;
            // Update the actual form input
            const input = document.querySelector('[name*="classLevel"]');
            if (input) { input.value = n; input.dispatchEvent(new Event('input')); }
            this.suggestions = topicsByClass[n] || [];
        },

        pickTopic(topic) {
            this.$refs.subjectInput.value = topic;
            this.$refs.subjectInput.dispatchEvent(new Event('input'));
            // Scroll to subject field
            this.$refs.subjectInput.focus();
        }
    };
}
</script>
{% endblock %}

{% block results_content %}
    {% if testData %}
        {# ── Structured test preview ── #}
        <div class="card mb-3">
            <div class="card-stamp"><div class="card-stamp-icon bg-primary"><i class="ti ti-file-text"></i></div></div>
            <div class="card-header">
                <h3 class="card-title">{{ testData.title }}</h3>
                <div class="card-actions">
                    <form method="post" action="{{ path('app_generate_test_save') }}" class="d-inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('save') }}">
                        <button type="submit" class="btn btn-ghost-success btn-sm"><i class="ti ti-device-floppy me-1"></i>Zapisz</button>
                    </form>
                    <a href="{{ path('app_generate_test_pdf') }}" class="btn btn-ghost-primary btn-sm" target="_blank"><i class="ti ti-file-type-pdf me-1"></i>PDF (uczeń)</a>
                    <a href="{{ path('app_generate_test_pdf', {answers: 1}) }}" class="btn btn-ghost-primary btn-sm" target="_blank"><i class="ti ti-file-type-pdf me-1"></i>PDF + klucz</a>
                </div>
            </div>
            <div class="card-body">
                {# Header preview #}
                <div class="border rounded p-3 mb-3 bg-light">
                    <div class="fw-bold text-center mb-2" style="font-size:1.1rem;">{{ testData.title }}</div>
                    <div class="row text-secondary" style="font-size:.85rem;">
                        <div class="col">Imię i nazwisko: ..........................</div>
                        <div class="col-auto">Klasa: ........</div>
                        <div class="col-auto">Data: ............</div>
                    </div>
                    <div class="text-end text-secondary mt-1" style="font-size:.85rem;">Suma punktów: ..... / {{ testData.totalPoints }} pkt</div>
                </div>

                {# Questions #}
                {% for i, q in testData.questions %}
                    <div class="border rounded p-3 mb-2">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="fw-bold">Zadanie {{ i + 1 }}.</span>
                            <span class="badge {{ q.type == 'closed' ? 'bg-blue-lt' : (q.type == 'true_false' ? 'bg-orange-lt' : 'bg-green-lt') }}">
                                {{ q.type == 'closed' ? 'ABCD' : (q.type == 'true_false' ? 'P/F' : 'Otwarte') }}
                                &middot; {{ q.points }} pkt
                            </span>
                        </div>
                        <div class="mb-2">{{ q.text }}</div>

                        {% if q.type == 'closed' and q.options is defined %}
                            {% set letters = ['A','B','C','D'] %}
                            <div class="row g-2">
                                {% for key, opt in q.options %}
                                    {% set isCorrect = q.correct is defined and letters[key] == q.correct %}
                                    <div class="col-6">
                                        <div class="d-flex align-items-center gap-2 p-2 border rounded {{ isCorrect ? 'border-success bg-success-lt' : '' }}">
                                            <span class="avatar avatar-xs rounded fw-bold {{ isCorrect ? 'bg-success text-white' : 'bg-primary-lt' }}" style="font-size:.7rem;">{{ letters[key] }}</span>
                                            <span style="font-size:.9rem;">{{ opt }}</span>
                                            {% if isCorrect %}<i class="ti ti-check ms-auto text-success"></i>{% endif %}
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        {% elseif q.type == 'true_false' %}
                            <div class="d-flex gap-3">
                                <div class="d-flex align-items-center gap-2 p-2 border rounded {{ q.correct == 'P' ? 'border-success bg-success-lt' : '' }}">
                                    <span class="avatar avatar-xs rounded fw-bold {{ q.correct == 'P' ? 'bg-success text-white' : 'bg-secondary-lt' }}" style="font-size:.7rem;">P</span> Prawda
                                    {% if q.correct == 'P' %}<i class="ti ti-check ms-1 text-success"></i>{% endif %}
                                </div>
                                <div class="d-flex align-items-center gap-2 p-2 border rounded {{ q.correct == 'F' ? 'border-success bg-success-lt' : '' }}">
                                    <span class="avatar avatar-xs rounded fw-bold {{ q.correct == 'F' ? 'bg-success text-white' : 'bg-secondary-lt' }}" style="font-size:.7rem;">F</span> Fałsz
                                    {% if q.correct == 'F' %}<i class="ti ti-check ms-1 text-success"></i>{% endif %}
                                </div>
                            </div>
                        {% elseif q.type == 'open' %}
                            <div class="text-secondary" style="font-size:.85rem;">
                                {% for line in range(1, q.lines|default(3)) %}
                                    <div style="border-bottom:1px dotted #ccc;height:1.8em;"></div>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        </div>

        {# Answer key #}
        <div class="card">
            <div class="card-stamp"><div class="card-stamp-icon bg-green"><i class="ti ti-key"></i></div></div>
            <div class="card-header"><h3 class="card-title">Klucz odpowiedzi</h3></div>
            <div class="card-body">
                {% for i, q in testData.questions %}
                    <div class="d-flex gap-2 mb-2 align-items-start">
                        <span class="badge bg-secondary-lt">{{ i + 1 }}</span>
                        <div>
                            {% if q.type == 'closed' %}
                                <span class="fw-bold text-primary">{{ q.correct }}</span>
                                {% if q.options is defined and q.correct is defined %}
                                    — {{ q.options[{'A':0,'B':1,'C':2,'D':3}[q.correct]] | default('') }}
                                {% endif %}
                            {% elseif q.type == 'true_false' %}
                                <span class="fw-bold {{ q.correct == 'P' ? 'text-success' : 'text-danger' }}">{{ q.correct == 'P' ? 'PRAWDA' : 'FAŁSZ' }}</span>
                            {% elseif q.type == 'open' %}
                                <span class="text-secondary">{{ q.answer | default('Brak modelu odpowiedzi') }}</span>
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>

    {% elseif testRaw %}
        {# Fallback — raw text #}
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Sprawdzian (tekst)</h3>
                <div class="card-actions">
                    <form method="post" action="{{ path('app_generate_test_save') }}" class="d-inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('save') }}">
                        <button type="submit" class="btn btn-ghost-success btn-sm"><i class="ti ti-device-floppy me-1"></i>Zapisz</button>
                    </form>
                </div>
            </div>
            <div class="card-body">
                <div class="result-box">{{ testRaw }}</div>
            </div>
        </div>
    {% else %}
        <div class="card border-0 bg-transparent shadow-none">
            <div class="card-body">
                <div class="empty">
                    <div class="empty-icon"><i class="ti ti-file-text" style="font-size: 3rem;"></i></div>
                    <p class="empty-title">Podgląd sprawdzianu</p>
                    <p class="empty-subtitle text-secondary">Wybierz klasę, aby zobaczyć propozycje tematów z podstawy programowej MEN.</p>
                </div>
            </div>
        </div>
    {% endif %}
{% endblock %}
