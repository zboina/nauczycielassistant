{% extends 'base.html.twig' %}

{% block title %}Konspekty lekcji — Nauczyciel Assistant{% endblock %}
{% block pretitle_text %}Konspekty lekcji{% endblock %}
{% block title_text %}Zapisane konspekty{% endblock %}

{% block page_actions %}
    <div class="btn-group">
        <a href="{{ path('app_lesson_plan_generate') }}" class="btn btn-primary btn-sm"><i class="ti ti-sparkles me-1"></i>Generuj AI</a>
        <a href="{{ path('app_lesson_plan_create_manual') }}" class="btn btn-outline-primary btn-sm"><i class="ti ti-plus me-1"></i>Nowy ręcznie</a>
    </div>
{% endblock %}

{% block body %}
{# Filters #}
<div class="d-flex gap-2 mb-3">
    <a href="{{ path('app_lesson_plan_index') }}" class="btn btn-sm {{ currentClass is null ? 'btn-primary' : 'btn-outline-primary' }}">Wszystkie</a>
    {% for cl in ['4','5','6','7','8'] %}
        <a href="{{ path('app_lesson_plan_index', {class: cl}) }}" class="btn btn-sm {{ currentClass == cl ? 'btn-primary' : 'btn-outline-primary' }}">Klasa {{ cl }}</a>
    {% endfor %}
</div>

{% if plans|length > 0 %}
<div x-data="lpTable()" x-init="init()">
    <div class="card mb-2">
        <div class="card-body py-2">
            <div class="row g-2 align-items-center">
                <div class="col">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text"><i class="ti ti-search"></i></span>
                        <input type="text" class="form-control" placeholder="Szukaj..." x-model="search" @input="filter()">
                        <button class="btn btn-outline-secondary" x-show="search" @click="search=''; filter()"><i class="ti ti-x"></i></button>
                    </div>
                </div>
                <div class="col-auto text-secondary small"><span x-text="filtered.length"></span> / {{ plans|length }}</div>
            </div>
        </div>
    </div>
    <div class="card">
        <div class="table-responsive">
            <table class="table table-vcenter card-table table-hover table-sm">
                <thead>
                    <tr>
                        <th style="width:40px;"></th>
                        <th style="cursor:pointer;" @click="sortBy('title')">Tytuł <i class="ti" :class="sf==='title'?(sd==='asc'?'ti-chevron-up':'ti-chevron-down'):''" style="font-size:.7rem;"></i></th>
                        <th style="width:55px;cursor:pointer;" @click="sortBy('class')">Kl.</th>
                        <th style="width:60px;">Min</th>
                        <th style="width:100px;cursor:pointer;" @click="sortBy('date')">Data</th>
                        <th style="width:150px;" class="text-end">Akcje</th>
                    </tr>
                </thead>
                <tbody>
                    <template x-for="p in filtered" :key="p.id">
                        <tr>
                            <td class="text-center"><template x-if="p.fav"><i class="ti ti-star-filled text-yellow"></i></template></td>
                            <td><a :href="p.showUrl" class="text-reset fw-medium" x-text="p.title"></a></td>
                            <td><span class="badge bg-primary-lt" x-text="p.cl"></span></td>
                            <td class="text-secondary" x-text="p.dur + ' min'"></td>
                            <td class="text-secondary" style="font-size:.8rem;" x-text="p.date"></td>
                            <td class="text-end text-nowrap">
                                <div class="btn-group">
                                    <a :href="p.showUrl" class="btn btn-ghost-primary btn-sm" title="Podgląd"><i class="ti ti-eye"></i></a>
                                    <a :href="p.editUrl" class="btn btn-ghost-blue btn-sm" title="Edytuj"><i class="ti ti-edit"></i></a>
                                    <a :href="p.pdfUrl" class="btn btn-ghost-primary btn-sm" target="_blank" title="PDF"><i class="ti ti-file-type-pdf"></i></a>
                                    <a :href="p.docxUrl" class="btn btn-ghost-blue btn-sm" title="DOCX"><i class="ti ti-file-type-doc"></i></a>
                                </div>
                            </td>
                        </tr>
                    </template>
                </tbody>
            </table>
        </div>
        <div x-show="filtered.length===0 && search" class="card-body text-center text-secondary py-3">Brak wyników</div>
    </div>
</div>
<script>
function lpTable() {
    return {
        all:[], filtered:[], search:'', sf:'date', sd:'desc',
        init() {
            this.all = [{% for p in plans %}{
                id:{{p.id}}, title:{{p.title|json_encode|raw}}, cl:{{p.classLevel|json_encode|raw}},
                dur:{{p.durationMinutes}}, date:{{ p.createdAt|date('d.m.Y')|json_encode|raw }},
                dateRaw:{{ p.createdAt|date('U') }}, fav:{{ p.isFavorite ? 'true':'false' }},
                showUrl:{{ path('app_lesson_plan_show',{id:p.id})|json_encode|raw }},
                editUrl:{{ path('app_lesson_plan_edit',{id:p.id})|json_encode|raw }},
                pdfUrl:{{ path('app_lesson_plan_pdf',{id:p.id})|json_encode|raw }},
                docxUrl:{{ path('app_lesson_plan_docx',{id:p.id})|json_encode|raw }}
            }{{ not loop.last ? ',' : '' }}{% endfor %}];
            this.filter();
        },
        filter() { var s=this.search.toLowerCase(); this.filtered=this.all.filter(function(p){return !s||p.title.toLowerCase().includes(s)||p.cl.includes(s);}); this.doSort(); },
        sortBy(f) { if(this.sf===f) this.sd=this.sd==='asc'?'desc':'asc'; else { this.sf=f; this.sd=f==='date'?'desc':'asc'; } this.doSort(); },
        doSort() { var f=this.sf, d=this.sd==='asc'?1:-1; this.filtered.sort(function(a,b){ var va,vb; if(f==='title'){va=a.title.toLowerCase();vb=b.title.toLowerCase();}else if(f==='class'){va=a.cl;vb=b.cl;}else{va=a.dateRaw;vb=b.dateRaw;} return va<vb?-d:va>vb?d:0; }); }
    };
}
</script>
{% else %}
    <div class="card">
        <div class="card-body">
            <div class="empty">
                <div class="empty-icon"><i class="ti ti-clipboard-text" style="font-size:2.5rem;"></i></div>
                <p class="empty-title">Brak zapisanych konspektów</p>
                <div class="empty-action">
                    <a href="{{ path('app_lesson_plan_generate') }}" class="btn btn-primary"><i class="ti ti-sparkles me-2"></i>Generuj konspekt</a>
                </div>
            </div>
        </div>
    </div>
{% endif %}
{% endblock %}
