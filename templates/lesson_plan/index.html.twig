{% extends 'base.html.twig' %}

{% block title %}Konspekty lekcji — Nauczyciel Assistant{% endblock %}
{% block pretitle_text %}Konspekty lekcji{% endblock %}
{% block title_text %}Zapisane konspekty{% endblock %}

{% block page_actions %}
    <a href="{{ path('app_lesson_plan_generate') }}" class="btn btn-primary btn-sm">
        <i class="ti ti-sparkles me-1"></i> Nowy konspekt
    </a>
{% endblock %}

{% block body %}
{# Filters #}
<div class="d-flex gap-2 mb-3">
    <a href="{{ path('app_lesson_plan_index') }}" class="btn btn-sm {{ currentClass is null ? 'btn-primary' : 'btn-outline-primary' }}">Wszystkie</a>
    {% for cl in ['4','5','6','7','8'] %}
        <a href="{{ path('app_lesson_plan_index', {class: cl}) }}" class="btn btn-sm {{ currentClass == cl ? 'btn-primary' : 'btn-outline-primary' }}">Klasa {{ cl }}</a>
    {% endfor %}
</div>

{% if plans|length > 0 %}
    <div class="row row-cards">
        {% for plan in plans %}
            <div class="col-md-6 col-xl-4">
                <div class="card">
                    {% if plan.isFavorite %}
                        <div class="card-status-start bg-yellow"></div>
                    {% endif %}
                    <div class="card-body">
                        <div class="d-flex align-items-start">
                            <div class="flex-fill">
                                <h3 class="card-title mb-1">
                                    <a href="{{ path('app_lesson_plan_show', {id: plan.id}) }}" class="text-reset">
                                        {{ plan.title }}
                                    </a>
                                </h3>
                                {% if plan.literature %}
                                    <div class="text-secondary small">{{ plan.literature.title }} — {{ plan.literature.author }}</div>
                                {% endif %}
                            </div>
                            {% if plan.isFavorite %}
                                <span class="text-yellow ms-2"><i class="ti ti-star-filled"></i></span>
                            {% endif %}
                        </div>
                        <div class="mt-3 d-flex gap-2 flex-wrap">
                            <span class="badge bg-primary-lt">Klasa {{ plan.classLevel }}</span>
                            <span class="badge bg-secondary-lt">{{ plan.durationMinutes }} min</span>
                            <span class="badge bg-secondary-lt">{{ plan.createdAt|date('d.m.Y') }}</span>
                        </div>
                    </div>
                    <div class="card-footer d-flex justify-content-between">
                        <a href="{{ path('app_lesson_plan_show', {id: plan.id}) }}" class="btn btn-primary btn-sm">
                            <i class="ti ti-eye me-1"></i>Otwórz
                        </a>
                        <a href="{{ path('app_lesson_plan_pdf', {id: plan.id}) }}" class="btn btn-ghost-primary btn-sm" target="_blank">
                            <i class="ti ti-file-type-pdf me-1"></i>PDF
                        </a>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% else %}
    <div class="card">
        <div class="card-body">
            <div class="empty">
                <div class="empty-icon"><i class="ti ti-clipboard-text" style="font-size: 2.5rem;"></i></div>
                <p class="empty-title">Brak zapisanych konspektów</p>
                <p class="empty-subtitle text-secondary">Wygeneruj pierwszy konspekt lekcji!</p>
                <div class="empty-action">
                    <a href="{{ path('app_lesson_plan_generate') }}" class="btn btn-primary">
                        <i class="ti ti-sparkles me-2"></i>Generuj konspekt
                    </a>
                </div>
            </div>
        </div>
    </div>
{% endif %}
{% endblock %}
