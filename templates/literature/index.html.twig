{% extends 'base.html.twig' %}

{% block title %}Lektury kl. 4-8 — Nauczyciel Assistant{% endblock %}
{% block pretitle_text %}Baza lektur{% endblock %}
{% block title_text %}Lektury obowiązkowe kl. 4-8{% endblock %}

{% set classColors = {'4': 'cyan', '5': 'teal', '6': 'blue', '7': 'green', '8': 'orange'} %}

{% block body %}
{# ── Filters ─────────────────────────── #}
<div class="card mb-4">
    <div class="card-body py-3">
        <div class="row g-3 align-items-end">
            <div class="col-auto">
                <div class="btn-group">
                    <a href="{{ path('app_literature_index', {q: search}) }}" class="btn btn-sm {{ currentClass is null ? 'btn-primary' : 'btn-outline-primary' }}">Wszystkie</a>
                    {% for cl in ['4','5','6','7','8'] %}
                        <a href="{{ path('app_literature_index', {class: cl, q: search}) }}" class="btn btn-sm {{ currentClass == cl ? 'btn-primary' : 'btn-outline-primary' }}">Klasa {{ cl }}</a>
                    {% endfor %}
                </div>
            </div>
            <div class="col">
                <form method="get" action="{{ path('app_literature_index') }}">
                    {% if currentClass %}<input type="hidden" name="class" value="{{ currentClass }}">{% endif %}
                    <div class="input-group input-group-sm">
                        <span class="input-group-text"><i class="ti ti-search"></i></span>
                        <input type="text" name="q" class="form-control" placeholder="Szukaj tytułu lub autora..." value="{{ search }}">
                        {% if search %}
                            <a href="{{ path('app_literature_index', {class: currentClass}) }}" class="btn btn-outline-secondary"><i class="ti ti-x"></i></a>
                        {% endif %}
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

{# ── Literature cards ────────────────── #}
<div class="row row-cards">
    {% for lit in literatures %}
        {% set color = classColors[lit.classLevel] | default('blue') %}
        <div class="col-md-6 col-xl-4">
            <div class="card">
                <div class="card-status-start bg-{{ color }}"></div>
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <span class="avatar avatar-lg rounded bg-{{ color }}-lt text-{{ color }}">
                                {{ lit.title|first }}
                            </span>
                        </div>
                        <div class="col">
                            <h3 class="card-title mb-1">
                                <a href="{{ path('app_literature_show', {id: lit.id}) }}" class="text-reset">{{ lit.title }}</a>
                            </h3>
                            <div class="text-secondary">{{ lit.author }}</div>
                        </div>
                    </div>
                    <div class="mt-3 d-flex gap-2 flex-wrap">
                        <span class="badge bg-{{ color }}-lt">Klasa {{ lit.classLevel }}</span>
                        {% if lit.epoch %}<span class="badge bg-secondary-lt">{{ lit.epoch }}</span>{% endif %}
                        {% if lit.isObligatory %}<span class="badge bg-red-lt">Obowiązkowa</span>{% endif %}
                    </div>
                    {% if lit.summary %}
                        <p class="text-secondary mt-3 mb-0" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; font-size: .85rem;">
                            {{ lit.summary }}
                        </p>
                    {% endif %}
                </div>
                <div class="card-footer d-flex align-items-center justify-content-between">
                    <span class="text-secondary"><i class="ti ti-help-circle me-1"></i>{{ lit.questions|length }} pytań</span>
                    <a href="{{ path('app_literature_show', {id: lit.id}) }}" class="btn btn-primary btn-sm">
                        Szczegóły <i class="ti ti-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    {% else %}
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="empty">
                        <div class="empty-icon"><i class="ti ti-book-off" style="font-size: 2.5rem;"></i></div>
                        <p class="empty-title">Brak wyników</p>
                        <p class="empty-subtitle text-secondary">Nie znaleziono lektur pasujących do kryteriów.</p>
                    </div>
                </div>
            </div>
        </div>
    {% endfor %}
</div>
{% endblock %}
