<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<style>
@page { margin: 15mm 18mm; }
body { font-family: 'DejaVu Sans', sans-serif; font-size: 10pt; line-height: 1.6; color: #000; }
.title { font-size: 13pt; font-weight: bold; text-align: center; margin-bottom: 15px; border-bottom: 2px solid #000; padding-bottom: 8px; }
.content { white-space: pre-wrap; }
.footer { margin-top: 15px; text-align: center; font-size: 7pt; color: #999; border-top: 1px solid #ddd; padding-top: 5px; }
</style>
</head>
<body>
<div class="title">{{ title }}</div>
<div class="content">{{ content }}</div>
<div class="footer">Wygenerowano w Nauczyciel Assistant</div>
</body>
</html>
