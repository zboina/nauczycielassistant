<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<style>
@page { margin: 12mm 15mm; }
body { font-family: 'DejaVu Sans', sans-serif; font-size: 9pt; line-height: 1.4; color: #000; }

.lp-header { border: 2px solid #000; padding: 8px 12px; margin-bottom: 10px; }
.lp-title { font-size: 13pt; font-weight: bold; text-align: center; margin-bottom: 4px; }
.lp-meta { font-size: 8pt; text-align: center; color: #555; }

.section-title { font-size: 9pt; font-weight: bold; text-transform: uppercase; color: #1a56db; border-bottom: 1.5px solid #1a56db; padding-bottom: 2px; margin: 10px 0 5px; letter-spacing: .5px; }

.two-col { display: table; width: 100%; }
.two-col .col { display: table-cell; width: 50%; vertical-align: top; padding-right: 8px; }
.two-col .col:last-child { padding-right: 0; padding-left: 8px; }

ul { margin: 0 0 4px; padding-left: 14px; }
li { margin-bottom: 2px; font-size: 9pt; }

.badge-row { margin-bottom: 6px; }
.badge { display: inline-block; background: #eef; border: 1px solid #ccd; padding: 1px 6px; border-radius: 3px; font-size: 7.5pt; margin: 1px 2px 1px 0; }
.badge-green { background: #efe; border-color: #cdc; }
.badge-purple { background: #f3edf7; border-color: #d4c5e0; }

.phase-box { border: 1px solid #ccc; margin-bottom: 6px; page-break-inside: avoid; }
.phase-header { background: #f0f0f0; padding: 4px 8px; font-weight: bold; font-size: 9pt; border-bottom: 1px solid #ccc; }
.phase-header-blue { background: #e8f0fe; }
.phase-header-green { background: #e6f4ea; }
.phase-header-orange { background: #fef3e2; }
.phase-badge { float: right; font-weight: normal; font-size: 8pt; color: #555; }

.activity-row { padding: 3px 8px; border-bottom: 1px dotted #ddd; font-size: 8.5pt; }
.activity-row:last-child { border-bottom: none; }
.activity-time { font-weight: bold; display: inline-block; min-width: 35px; color: #555; }

.three-col { display: table; width: 100%; }
.three-col .col { display: table-cell; width: 33.33%; vertical-align: top; padding: 6px; }
.info-box { border: 1px solid #ddd; padding: 6px; height: 100%; }
.info-title { font-weight: bold; font-size: 8pt; text-transform: uppercase; color: #555; margin-bottom: 3px; }
.info-content { font-size: 8.5pt; }

.lp-footer { margin-top: 10px; text-align: center; font-size: 7pt; color: #999; border-top: 1px solid #ddd; padding-top: 4px; }
</style>
</head>
<body>

{% if lpData %}

<div class="lp-header">
    <div class="lp-title">{{ lpData.title | default(plan.lessonTopic) }}</div>
    <div class="lp-meta">
        Klasa {{ lpData.classLevel | default(plan.classLevel) }}
        | {{ lpData.duration | default(plan.durationMinutes) }} min
        {% if lpData.literature is defined %} | {{ lpData.literature }}{% endif %}
        | {{ plan.createdAt | date('d.m.Y') }}
    </div>
</div>

{% if lpData.curriculumRef is defined and lpData.curriculumRef %}
<div class="section-title">Podstawa programowa</div>
<div class="badge-row">
    {% for ref in lpData.curriculumRef %}
        <span class="badge badge-purple">{{ ref }}</span>
    {% endfor %}
</div>
{% endif %}

<div class="two-col">
    <div class="col">
        {% if lpData.goalsGeneral is defined and lpData.goalsGeneral %}
        <div class="section-title">Cele ogólne</div>
        <ul>{% for g in lpData.goalsGeneral %}<li>{{ g }}</li>{% endfor %}</ul>
        {% endif %}
    </div>
    <div class="col">
        {% if lpData.goalsSpecific is defined and lpData.goalsSpecific %}
        <div class="section-title">Cele szczegółowe</div>
        <ul>{% for g in lpData.goalsSpecific %}<li>{{ g }}</li>{% endfor %}</ul>
        {% endif %}
    </div>
</div>

<div class="two-col">
    <div class="col">
        {% if lpData.methods is defined and lpData.methods %}
        <div class="section-title">Metody i formy pracy</div>
        <div class="badge-row">{% for m in lpData.methods %}<span class="badge">{{ m }}</span>{% endfor %}</div>
        {% endif %}
    </div>
    <div class="col">
        {% if lpData.materials is defined and lpData.materials %}
        <div class="section-title">Środki dydaktyczne</div>
        <div class="badge-row">{% for m in lpData.materials %}<span class="badge badge-green">{{ m }}</span>{% endfor %}</div>
        {% endif %}
    </div>
</div>

{% if lpData.phases is defined %}
<div class="section-title">Przebieg lekcji</div>
{% set phaseHeaderClasses = {'Faza wstępna': 'phase-header-blue', 'Faza realizacji': 'phase-header-green', 'Faza podsumowująca': 'phase-header-orange'} %}
{% for phase in lpData.phases %}
    <div class="phase-box">
        <div class="phase-header {{ phaseHeaderClasses[phase.name] | default('') }}">
            {{ phase.name }}
            <span class="phase-badge">{{ phase.duration }}</span>
        </div>
        {% if phase.activities is defined %}
            {% for act in phase.activities %}
                <div class="activity-row">
                    <span class="activity-time">{{ act.time }}</span>
                    {{ act.description }}
                </div>
            {% endfor %}
        {% endif %}
    </div>
{% endfor %}
{% endif %}

<div class="three-col">
    <div class="col">
        {% if lpData.homework is defined %}
        <div class="info-box">
            <div class="info-title">Praca domowa</div>
            <div class="info-content">{{ lpData.homework }}</div>
        </div>
        {% endif %}
    </div>
    <div class="col">
        {% if lpData.evaluation is defined %}
        <div class="info-box">
            <div class="info-title">Ewaluacja</div>
            <div class="info-content">{{ lpData.evaluation }}</div>
        </div>
        {% endif %}
    </div>
    <div class="col">
        <div class="info-box">
            <div class="info-title">Uwagi metodyczne</div>
            <div class="info-content">
                {% if lpData.notesForSPE is defined %}<div style="margin-bottom:3px;"><strong>SPE:</strong> {{ lpData.notesForSPE }}</div>{% endif %}
                {% if lpData.notesForGifted is defined %}<div><strong>Zdolni:</strong> {{ lpData.notesForGifted }}</div>{% endif %}
            </div>
        </div>
    </div>
</div>

<div class="lp-footer">Wygenerowano w Nauczyciel Assistant</div>

{% else %}
<div style="text-align:center;margin-bottom:12px;">
    <div style="font-size:13pt;font-weight:bold;">Konspekt: {{ plan.lessonTopic }}</div>
    <div style="font-size:9pt;color:#555;">Klasa {{ plan.classLevel }} | {{ plan.durationMinutes }} min</div>
</div>
<div style="white-space:pre-wrap;font-size:9.5pt;">{{ plan.content }}</div>
{% endif %}

</body>
</html>
