{% extends 'base.html.twig' %}

{% block title %}Wynik skanowania — Nauczyciel Assistant{% endblock %}
{% block pretitle_text %}Skaner odpowiedzi{% endblock %}
{% block title_text %}Wynik skanowania{% endblock %}

{% block page_actions %}
    <a href="{{ path('app_scanner_index') }}" class="btn btn-outline-secondary btn-sm"><i class="ti ti-arrow-left me-1"></i>Skanuj kolejną</a>
{% endblock %}

{% set g = grading %}

{% block body %}
<div class="row g-4">
    {# Left: results #}
    <div class="col-lg-7">

        {% if g %}
        {% set pctColor = g.percent >= 85 ? 'green' : (g.percent >= 70 ? 'blue' : (g.percent >= 50 ? 'yellow' : (g.percent >= 30 ? 'orange' : 'red'))) %}
        {# Score summary #}
        <div class="card mb-3">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-auto">
                        <div class="avatar avatar-xl rounded bg-{{ pctColor }}-lt text-{{ pctColor }}" style="font-size:1.5rem;font-weight:bold;">
                            {{ g.percent }}%
                        </div>
                    </div>
                    <div class="col">
                        <h2 class="mb-1">
                            {{ scanned.studentName ?? 'Uczeń (nieodczytane)' }}
                        </h2>
                        <div class="text-secondary">
                            {{ sourceTitle }}
                            {% if scanned.examCode is defined and scanned.examCode %}
                                <span class="badge bg-primary-lt ms-2">{{ scanned.examCode }}</span>
                            {% endif %}
                        </div>
                    </div>
                    <div class="col-auto text-end">
                        <div class="display-6 fw-bold text-{{ pctColor }}">{{ g.correct }} / {{ g.total }}</div>
                        <div class="text-secondary small">poprawnych</div>
                    </div>
                </div>
            </div>
        </div>

        {# Stats row #}
        <div class="row g-3 mb-3">
            <div class="col-4">
                <div class="card">
                    <div class="card-body text-center py-3">
                        <div class="h1 mb-0 text-green">{{ g.correct }}</div>
                        <div class="text-secondary small">Poprawne</div>
                    </div>
                </div>
            </div>
            <div class="col-4">
                <div class="card">
                    <div class="card-body text-center py-3">
                        <div class="h1 mb-0 text-red">{{ g.incorrect }}</div>
                        <div class="text-secondary small">Błędne</div>
                    </div>
                </div>
            </div>
            <div class="col-4">
                <div class="card">
                    <div class="card-body text-center py-3">
                        <div class="h1 mb-0 text-secondary">{{ g.unanswered }}</div>
                        <div class="text-secondary small">Bez odpowiedzi</div>
                    </div>
                </div>
            </div>
        </div>

        {# Answer details table #}
        <div class="card">
            <div class="card-header">
                <h3 class="card-title"><i class="ti ti-list-check me-2"></i>Szczegóły odpowiedzi</h3>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-vcenter card-table">
                        <thead>
                            <tr>
                                <th class="text-center" style="width:50px;">Nr</th>
                                <th class="text-center">Klucz</th>
                                <th class="text-center">Uczeń</th>
                                <th class="text-center" style="width:80px;">Wynik</th>
                                <th>Weryfikacja AI</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for d in g.details %}
                                <tr class="{{ d.status == 'błędna' ? 'bg-red-lt' : (d.status == 'brak' ? 'bg-light' : '') }}">
                                    <td class="text-center fw-bold">{{ d.number }}</td>
                                    <td class="text-center">
                                        <span class="avatar avatar-xs rounded bg-primary-lt fw-bold" style="font-size:.7rem;">{{ d.correct }}</span>
                                    </td>
                                    <td class="text-center">
                                        {% if d.student %}
                                            <span class="avatar avatar-xs rounded fw-bold {{ d.status == 'poprawna' ? 'bg-green text-white' : 'bg-red text-white' }}" style="font-size:.7rem;">{{ d.student }}</span>
                                        {% else %}
                                            <span class="text-secondary">—</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-center">
                                        {% if d.status == 'poprawna' %}
                                            <span class="badge bg-green"><i class="ti ti-check me-1"></i>OK</span>
                                        {% elseif d.status == 'błędna' %}
                                            <span class="badge bg-red"><i class="ti ti-x me-1"></i>Błąd</span>
                                        {% else %}
                                            <span class="badge bg-secondary">Brak</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-secondary" style="font-size:.75rem;">
                                        {% if scanned.verification is defined and scanned.verification[d.number ~ ''] is defined %}
                                            {{ scanned.verification[d.number ~ ''] }}
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        {% else %}
        {# No grading — show raw scanned answers #}
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <span class="avatar avatar-xl rounded bg-orange-lt text-orange"><i class="ti ti-alert-triangle" style="font-size:1.5rem;"></i></span>
                    <div>
                        <h2 class="mb-1">{{ scanned.studentName ?? 'Uczeń' }}</h2>
                        <div class="text-secondary">
                            Nie znaleziono klucza odpowiedzi
                            {% if scanned.examCode is defined and scanned.examCode %}
                                — kod: <strong>{{ scanned.examCode }}</strong>
                            {% endif %}
                        </div>
                    </div>
                </div>
                <h4 class="mb-2">Odczytane odpowiedzi:</h4>
                <div class="d-flex flex-wrap gap-2">
                    {% for num, ans in scanned.answers %}
                        <div class="border rounded p-2 text-center" style="min-width:50px;">
                            <div class="small text-secondary">{{ num }}</div>
                            <div class="fw-bold fs-4">{{ ans ?? '—' }}</div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
        {% endif %}
    </div>

    {# Right: photo + info #}
    <div class="col-lg-5">
        {# Scanned image #}
        <div class="card mb-3">
            <div class="card-header"><h3 class="card-title"><i class="ti ti-photo me-2"></i>Zeskanowane zdjęcie</h3></div>
            <div class="card-body text-center">
                <img src="{{ imageData }}" style="max-width:100%;max-height:400px;" class="rounded border">
            </div>
        </div>

        {# AI confidence #}
        <div class="card mb-3">
            <div class="card-header"><h3 class="card-title"><i class="ti ti-robot me-2"></i>Pewność odczytu</h3></div>
            <div class="card-body">
                {% set confColor = scanned.confidence == 'wysoka' ? 'green' : (scanned.confidence == 'średnia' ? 'yellow' : 'red') %}
                <div class="d-flex align-items-center gap-3">
                    <span class="badge bg-{{ confColor }} fs-5 px-3">{{ scanned.confidence|upper }}</span>
                    {% if scanned.notes is defined and scanned.notes %}
                        <div class="text-secondary" style="font-size:.85rem;">{{ scanned.notes }}</div>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Actions #}
        <div class="card">
            <div class="card-body d-flex flex-column gap-2">
                <a href="{{ path('app_scanner_index') }}" class="btn btn-primary">
                    <i class="ti ti-scan me-2"></i>Skanuj kolejną kartkę
                </a>
                <button class="btn btn-outline-secondary" onclick="window.print()">
                    <i class="ti ti-printer me-2"></i>Drukuj wynik
                </button>
            </div>
        </div>
    </div>
</div>
{% endblock %}
