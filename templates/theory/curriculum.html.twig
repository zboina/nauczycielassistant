{% extends 'base.html.twig' %}

{% block title %}Podstawa programowa {{ data.label }} — Nauczyciel Assistant{% endblock %}
{% block pretitle_text %}Teoria{% endblock %}
{% block title_text %}Podstawa programowa MEN 2024{% endblock %}

{% block page_actions %}
    <div class="btn-group">
        <a href="{{ path('app_theory_curriculum', {group: '4-6'}) }}" class="btn btn-sm {{ group == '4-6' ? 'btn-primary' : 'btn-outline-primary' }}">Kl. IV–VI</a>
        <a href="{{ path('app_theory_curriculum', {group: '7-8'}) }}" class="btn btn-sm {{ group == '7-8' ? 'btn-primary' : 'btn-outline-primary' }}">Kl. VII–VIII</a>
    </div>
{% endblock %}

{% block body %}
<div class="row g-4">
    <div class="col-lg-8">
        {# Literary education #}
        <div class="card mb-3">
            <div class="card-status-start bg-blue"></div>
            <div class="card-header">
                <h3 class="card-title"><i class="ti ti-book me-2"></i>I. Kształcenie literackie i kulturowe</h3>
                <div class="card-actions"><span class="badge bg-blue-lt">{{ data.label }}</span></div>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    {% for req in data.literary %}
                        <div class="list-group-item">
                            <div class="d-flex gap-2">
                                <span class="badge bg-blue-lt flex-shrink-0">I.{{ loop.index }}</span>
                                <div>{{ req }}</div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>

        {# Language education #}
        <div class="card mb-3">
            <div class="card-status-start bg-green"></div>
            <div class="card-header">
                <h3 class="card-title"><i class="ti ti-language me-2"></i>II. Kształcenie językowe</h3>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    {% for req in data.language %}
                        <div class="list-group-item">
                            <div class="d-flex gap-2">
                                <span class="badge bg-green-lt flex-shrink-0">II.{{ loop.index }}</span>
                                <div>{{ req }}</div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>

        {# Writing forms #}
        <div class="card mb-3">
            <div class="card-status-start bg-orange"></div>
            <div class="card-header">
                <h3 class="card-title"><i class="ti ti-writing me-2"></i>III. Tworzenie wypowiedzi</h3>
            </div>
            <div class="card-body">
                <p class="mb-2 fw-medium">Wymagane formy wypowiedzi:</p>
                <div class="d-flex flex-wrap gap-2">
                    {% for form in data.writing %}
                        <span class="badge bg-orange-lt" style="font-size:.8rem;">{{ form }}</span>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        {# Readings #}
        <div class="card mb-3">
            <div class="card-status-start bg-purple"></div>
            <div class="card-header">
                <h3 class="card-title"><i class="ti ti-books me-2"></i>Lektury obowiązkowe</h3>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    {% for reading in data.readings %}
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="fw-medium" style="font-size:.85rem;">{{ reading.title }}</div>
                                    {% if reading.author %}
                                        <div class="text-secondary" style="font-size:.75rem;">{{ reading.author }}</div>
                                    {% endif %}
                                </div>
                                <div class="d-flex gap-1 flex-shrink-0 ms-2">
                                    {% if reading.type is defined %}
                                        <span class="badge {{ reading.type == 'całość' ? 'bg-green-lt' : (reading.type == 'wiersze' ? 'bg-blue-lt' : 'bg-secondary-lt') }}" style="font-size:.6rem;">{{ reading.type }}</span>
                                    {% endif %}
                                    <span class="badge bg-purple-lt" style="font-size:.6rem;">{{ reading.class }}</span>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
            <div class="card-footer text-center">
                <a href="{{ path('app_theory_readings') }}" class="text-primary small fw-medium">
                    <i class="ti ti-arrow-right me-1"></i>Pełna lista lektur 2025/2026 + zmiany
                </a>
            </div>
        </div>

        {# Quick nav #}
        <div class="card">
            <div class="card-header"><h3 class="card-title"><i class="ti ti-compass me-2"></i>Zobacz też</h3></div>
            <div class="card-body d-flex flex-column gap-2">
                <a href="{{ path('app_theory_readings') }}" class="btn btn-outline-teal btn-sm w-100"><i class="ti ti-books me-1"></i>Lektury 2025/2026</a>
                <a href="{{ path('app_theory_genres') }}" class="btn btn-outline-green btn-sm w-100"><i class="ti ti-category me-1"></i>Rodzaje i gatunki</a>
                <a href="{{ path('app_theory_stylistics') }}" class="btn btn-outline-purple btn-sm w-100"><i class="ti ti-wand me-1"></i>Środki stylistyczne</a>
                <a href="{{ path('app_theory_writing_forms') }}" class="btn btn-outline-orange btn-sm w-100"><i class="ti ti-writing me-1"></i>Formy wypowiedzi</a>
                <a href="{{ path('app_theory_grammar') }}" class="btn btn-outline-red btn-sm w-100"><i class="ti ti-abc me-1"></i>Gramatyka i ortografia</a>
                <a href="{{ path('app_theory_curriculum', {group: otherGroup}) }}" class="btn btn-outline-primary btn-sm w-100"><i class="ti ti-arrow-right me-1"></i>{{ otherLabel }}</a>
            </div>
        </div>
    </div>
</div>

<div class="card mt-3">
    <div class="card-body text-center">
        <div class="text-secondary small">
            <i class="ti ti-info-circle me-1"></i>
            Źródło: Rozporządzenie MEN z 28 czerwca 2024 r. (Dz.U. 2024 poz. 996) — Podstawa programowa kształcenia ogólnego
        </div>
    </div>
</div>
{% endblock %}
