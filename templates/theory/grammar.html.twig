{% extends 'base.html.twig' %}

{% block title %}Gramatyka i ortografia — Nauczyciel Assistant{% endblock %}
{% block pretitle_text %}Teoria{% endblock %}
{% block title_text %}Gramatyka i ortografia{% endblock %}

{% block page_actions %}
    <a href="{{ path('app_theory_index') }}" class="btn btn-outline-secondary btn-sm"><i class="ti ti-arrow-left me-1"></i>Teoria</a>
{% endblock %}

{% block body %}
{# ── Parts of speech ── #}
<div class="card mb-4">
    <div class="card-status-start bg-blue"></div>
    <div class="card-header">
        <h3 class="card-title"><i class="ti ti-abc me-2"></i>Części mowy</h3>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-vcenter card-table table-striped">
                <thead>
                    <tr>
                        <th style="width:140px;">Część mowy</th>
                        <th style="width:180px;">Pytanie</th>
                        <th>Cechy / odmiana</th>
                        <th style="width:180px;">Przykłady</th>
                        <th style="width:70px;" class="text-center">Klasa</th>
                    </tr>
                </thead>
                <tbody>
                    {% for pos in partsOfSpeech %}
                        <tr>
                            <td class="fw-bold">{{ pos.name }}</td>
                            <td><span class="text-primary">{{ pos.question }}</span></td>
                            <td style="font-size:.85rem;">{{ pos.features }}</td>
                            <td style="font-size:.85rem;font-style:italic;">{{ pos.examples }}</td>
                            <td class="text-center"><span class="badge bg-blue-lt">{{ pos.level }}</span></td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{# ── Sentence parts quick ref ── #}
<div class="card mb-4">
    <div class="card-status-start bg-green"></div>
    <div class="card-header">
        <h3 class="card-title"><i class="ti ti-puzzle me-2"></i>Części zdania</h3>
        <div class="card-actions"><span class="badge bg-green-lt">kl. 4-6</span></div>
    </div>
    <div class="card-body">
        <div class="row g-3">
            {% set sentenceParts = [
                {name: 'Podmiot', question: 'kto? co?', color: 'blue', desc: 'O kim/czym mowa w zdaniu'},
                {name: 'Orzeczenie', question: 'co robi? co się dzieje?', color: 'red', desc: 'Co podmiot robi'},
                {name: 'Przydawka', question: 'jaki? który? czyj? ile?', color: 'purple', desc: 'Określa rzeczownik'},
                {name: 'Dopełnienie', question: 'kogo? czego? komu? itd.', color: 'orange', desc: 'Uzupełnia orzeczenie'},
                {name: 'Okolicznik', question: 'jak? gdzie? kiedy? dlaczego?', color: 'teal', desc: 'Okoliczności czynności'},
            ] %}
            {% for part in sentenceParts %}
                <div class="col-md-4 col-lg">
                    <div class="border rounded p-3 h-100 text-center">
                        <div class="fw-bold text-{{ part.color }} mb-1">{{ part.name }}</div>
                        <div class="text-primary small mb-1">{{ part.question }}</div>
                        <div class="text-secondary" style="font-size:.78rem;">{{ part.desc }}</div>
                    </div>
                </div>
            {% endfor %}
        </div>
        <div class="mt-3 p-3 border rounded bg-light">
            <div class="fw-medium mb-1">Przykład rozbioru zdania:</div>
            <div style="font-size:.9rem;">
                <span class="badge bg-blue-lt">Mały chłopiec</span>
                <span class="text-secondary mx-1">(podmiot z przydawką)</span>
                <span class="badge bg-red-lt">biegał</span>
                <span class="text-secondary mx-1">(orzeczenie)</span>
                <span class="badge bg-teal-lt">szybko</span>
                <span class="text-secondary mx-1">(okolicznik sposobu)</span>
                <span class="badge bg-teal-lt">po podwórku</span>
                <span class="text-secondary mx-1">(okolicznik miejsca)</span>
            </div>
        </div>
    </div>
</div>

{# ── Spelling rules ── #}
<div class="card mb-4">
    <div class="card-status-start bg-red"></div>
    <div class="card-header">
        <h3 class="card-title"><i class="ti ti-writing-sign me-2"></i>Zasady ortografii</h3>
    </div>
    <div class="card-body">
        <div class="row g-3">
            {% for rule in spellingRules %}
                <div class="col-md-6">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h4 class="fw-bold mb-0" style="font-size:.95rem;">{{ rule.title }}</h4>
                            <span class="badge bg-red-lt flex-shrink-0 ms-2">kl. {{ rule.level }}</span>
                        </div>
                        {% for r in rule.rules %}
                            <div class="d-flex gap-2 mb-2 align-items-start">
                                <i class="ti ti-point-filled text-red flex-shrink-0" style="margin-top:2px;"></i>
                                <div style="font-size:.85rem;">{{ r }}</div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
</div>

{# ── Sentence types ── #}
<div class="card">
    <div class="card-status-start bg-orange"></div>
    <div class="card-header">
        <h3 class="card-title"><i class="ti ti-sitemap me-2"></i>Typy zdań</h3>
        <div class="card-actions"><span class="badge bg-orange-lt">kl. 5-8</span></div>
    </div>
    <div class="card-body">
        <div class="row g-4">
            <div class="col-md-6">
                <h4 class="fw-bold mb-3" style="font-size:.9rem;">Zdania złożone współrzędnie</h4>
                {% set coordinated = [
                    {name: 'Łączne', conj: 'i, oraz, a (= i)', example: 'Padał deszcz i wiał wiatr.'},
                    {name: 'Rozłączne', conj: 'lub, albo, bądź', example: 'Pójdziemy do kina lub zostaniemy w domu.'},
                    {name: 'Przeciwstawne', conj: 'ale, lecz, jednak, a (= ale)', example: 'Chciał iść, ale padało.'},
                    {name: 'Wynikowe', conj: 'więc, zatem, dlatego, toteż', example: 'Padało, więc zostaliśmy w domu.'},
                ] %}
                {% for type in coordinated %}
                    <div class="border rounded p-2 mb-2">
                        <div class="fw-medium">{{ type.name }} <span class="text-primary small">({{ type.conj }})</span></div>
                        <div class="text-secondary" style="font-size:.82rem;font-style:italic;">{{ type.example }}</div>
                    </div>
                {% endfor %}
            </div>
            <div class="col-md-6">
                <h4 class="fw-bold mb-3" style="font-size:.9rem;">Zdania złożone podrzędnie</h4>
                {% set subordinated = [
                    {name: 'Dopełnieniowe', conj: 'że, aby, czy', example: 'Wiem, że masz rację.'},
                    {name: 'Przydawkowe', conj: 'który, jaki', example: 'Książka, którą czytam, jest ciekawa.'},
                    {name: 'Okolicznikowe czasu', conj: 'gdy, kiedy, zanim', example: 'Gdy padał deszcz, siedzieliśmy w domu.'},
                    {name: 'Okolicznikowe przyczyny', conj: 'ponieważ, bo, gdyż', example: 'Nie poszedł, ponieważ był chory.'},
                    {name: 'Okolicznikowe warunku', conj: 'jeśli, gdyby', example: 'Jeśli przyjdziesz, będę szczęśliwy.'},
                ] %}
                {% for type in subordinated %}
                    <div class="border rounded p-2 mb-2">
                        <div class="fw-medium">{{ type.name }} <span class="text-primary small">({{ type.conj }})</span></div>
                        <div class="text-secondary" style="font-size:.82rem;font-style:italic;">{{ type.example }}</div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
