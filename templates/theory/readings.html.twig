{% extends 'base.html.twig' %}

{% block title %}Lektury 2025/2026 — Nauczyciel Assistant{% endblock %}
{% block pretitle_text %}Teoria{% endblock %}
{% block title_text %}Lista lektur obowiązkowych i uzupełniających 2025/2026{% endblock %}

{% block page_actions %}
    <a href="{{ path('app_theory_index') }}" class="btn btn-outline-secondary btn-sm"><i class="ti ti-arrow-left me-1"></i>Teoria</a>
{% endblock %}

{% block body %}
<div class="alert alert-info mb-4">
    <div class="d-flex align-items-center gap-2">
        <i class="ti ti-info-circle flex-shrink-0"></i>
        <div>
            <strong>Podstawa prawna:</strong> Rozporządzenie MEN z 28 czerwca 2024 r. (Dz.U. 2024 poz. 996).
            Obowiązuje w roku szkolnym 2025/2026 (okres przejściowy do nowej PP od 1.09.2026).
        </div>
    </div>
</div>

{# ═══ KLASY IV-VI — OBOWIĄZKOWE ═══ #}
<div class="card mb-4">
    <div class="card-status-start bg-blue"></div>
    <div class="card-header">
        <h3 class="card-title"><i class="ti ti-book-2 me-2"></i>Klasy IV–VI — Lektury obowiązkowe</h3>
    </div>
    <div class="card-body p-0">
        <h4 class="px-3 pt-3 pb-1 text-uppercase text-secondary" style="font-size:.75rem;letter-spacing:.05em;">Utwory w całości</h4>
        <div class="list-group list-group-flush">
            {% set mandatory46 = [
                {author: 'Jan Brzechwa', title: 'Akademia Pana Kleksa'},
                {author: 'Janusz Christa', title: 'Kajko i Kokosz. Szkoła latania (komiks)'},
                {author: 'C.S. Lewis', title: 'Opowieści z Narnii. Lew, czarownica i stara szafa'},
                {author: 'Ferenc Molnár', title: 'Chłopcy z Placu Broni'},
                {author: 'J.R.R. Tolkien', title: 'Hobbit, czyli tam i z powrotem'},
            ] %}
            {% for r in mandatory46 %}
                <div class="list-group-item">
                    <div class="fw-medium">{{ r.title }}</div>
                    <div class="text-secondary small">{{ r.author }}</div>
                </div>
            {% endfor %}
        </div>

        <h4 class="px-3 pt-3 pb-1 text-uppercase text-secondary" style="font-size:.75rem;letter-spacing:.05em;">Fragmenty / w wyborze</h4>
        <div class="list-group list-group-flush">
            {% set fragments46 = [
                {author: 'René Goscinny, Jean-Jacques Sempé', title: 'Mikołajek (wybrane opowiadania)'},
                {author: 'Ignacy Krasicki', title: 'Bajki (wybór)'},
                {author: 'Adam Mickiewicz', title: 'Pan Tadeusz (fragmenty)'},
                {author: 'Józef Wybicki', title: 'Mazurek Dąbrowskiego'},
                {author: 'Maria Konopnicka', title: 'Rota', note: 'NOWA od 2024'},
                {author: '', title: 'Mity greckie: Prometeusz, Syzyf, Demeter i Kora, Dedal i Ikar, Tezeusz i Ariadna, Orfeusz i Eurydyka'},
                {author: '', title: 'Biblia — stworzenie świata i człowieka, przypowieści: o siewcy, o talentach, o synu marnotrawnym, o miłosiernym Samarytaninie'},
                {author: '', title: 'Podania i legendy polskie (wybór)'},
                {author: '', title: 'Baśnie polskie i europejskie (wybór)'},
            ] %}
            {% for r in fragments46 %}
                <div class="list-group-item">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="fw-medium">{{ r.title }}</div>
                            {% if r.author %}<div class="text-secondary small">{{ r.author }}</div>{% endif %}
                        </div>
                        {% if r.note is defined %}<span class="badge bg-green-lt">{{ r.note }}</span>{% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>

        <h4 class="px-3 pt-3 pb-1 text-uppercase text-secondary" style="font-size:.75rem;letter-spacing:.05em;">Poezja — wiersze w wyborze</h4>
        <div class="card-body pt-0">
            <div class="d-flex flex-wrap gap-2">
                {% for poet in ['Jan Brzechwa', 'Konstanty Ildefons Gałczyński', 'Anna Kamieńska', 'Joanna Kulmowa', 'Adam Mickiewicz', 'Juliusz Słowacki', 'Leopold Staff', 'Julian Tuwim', 'Jan Twardowski'] %}
                    <span class="badge bg-blue-lt">{{ poet }}</span>
                {% endfor %}
            </div>
        </div>
    </div>
</div>

{# ═══ KLASY VII-VIII — OBOWIĄZKOWE ═══ #}
<div class="card mb-4">
    <div class="card-status-start bg-green"></div>
    <div class="card-header">
        <h3 class="card-title"><i class="ti ti-book-2 me-2"></i>Klasy VII–VIII — Lektury obowiązkowe</h3>
    </div>
    <div class="card-body p-0">
        <h4 class="px-3 pt-3 pb-1 text-uppercase text-secondary" style="font-size:.75rem;letter-spacing:.05em;">Utwory w całości</h4>
        <div class="list-group list-group-flush">
            {% set mandatory78 = [
                {author: 'Charles Dickens', title: 'Opowieść wigilijna'},
                {author: 'Aleksander Fredro', title: 'Zemsta'},
                {author: 'Aleksander Kamiński', title: 'Kamienie na szaniec'},
                {author: 'Adam Mickiewicz', title: 'Dziady część II'},
                {author: 'Antoine de Saint-Exupéry', title: 'Mały Książę'},
                {author: 'Juliusz Słowacki', title: 'Balladyna'},
            ] %}
            {% for r in mandatory78 %}
                <div class="list-group-item">
                    <div class="fw-medium">{{ r.title }}</div>
                    <div class="text-secondary small">{{ r.author }}</div>
                </div>
            {% endfor %}
        </div>

        <h4 class="px-3 pt-3 pb-1 text-uppercase text-secondary" style="font-size:.75rem;letter-spacing:.05em;">Fragmenty / w wyborze</h4>
        <div class="list-group list-group-flush">
            {% set fragments78 = [
                {author: 'Jan Kochanowski', title: 'Fraszki (wybór), pieśń, Treny VII i VIII'},
                {author: 'Adam Mickiewicz', title: 'Reduta Ordona, Świtezianka'},
                {author: 'Adam Mickiewicz', title: 'Pan Tadeusz (ks. I, II, IV, X, XI, XII)', note: 'ZMIANA 2024: wcześniej w całości'},
                {author: 'Sławomir Mrożek', title: 'Artysta'},
                {author: 'Henryk Sienkiewicz', title: 'Latarnik'},
                {author: 'Henryk Sienkiewicz', title: 'Quo vadis (fragmenty)', note: 'ZMIANA 2024: wcześniej w całości'},
                {author: 'Stefan Żeromski', title: 'Syzyfowe prace (fragmenty)', note: 'ZMIANA 2024: wcześniej w całości'},
                {author: 'Stanisław Jerzy Lec', title: 'Aforyzmy (wybór)'},
            ] %}
            {% for r in fragments78 %}
                <div class="list-group-item">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="fw-medium">{{ r.title }}</div>
                            {% if r.author %}<div class="text-secondary small">{{ r.author }}</div>{% endif %}
                        </div>
                        {% if r.note is defined %}<span class="badge bg-orange-lt" style="font-size:.65rem;">{{ r.note }}</span>{% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>

        <h4 class="px-3 pt-3 pb-1 text-uppercase text-secondary" style="font-size:.75rem;letter-spacing:.05em;">Poezja — wiersze w wyborze (+ poeci z kl. IV-VI)</h4>
        <div class="card-body pt-0">
            <div class="d-flex flex-wrap gap-2">
                {% for poet in ['Krzysztof Kamil Baczyński', 'Zbigniew Herbert', 'Bolesław Leśmian', 'Czesław Miłosz', 'Tadeusz Różewicz', 'Wisława Szymborska'] %}
                    <span class="badge bg-green-lt">{{ poet }}</span>
                {% endfor %}
            </div>
        </div>
    </div>
</div>

{# ═══ ZMIANY 2024 ═══ #}
