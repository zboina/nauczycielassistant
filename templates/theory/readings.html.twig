    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-vcenter card-table">
                <thead>
                    <tr><th>Zmiana</th><th>Autor</th><th>Tytuł</th><th>Klasy</th></tr>
                </thead>
                <tbody>
                    <tr class="bg-green-lt">
                        <td><span class="badge bg-green">DODANE</span></td>
                        <td>Maria Konopnicka</td><td>Rota</td><td>IV-VI</td>
                    </tr>
                    <tr class="bg-red-lt">
                        <td><span class="badge bg-red">USUNIĘTE</span></td>
                        <td>Adam Mickiewicz</td><td>Powrót taty, Pani Twardowska</td><td>IV-VI</td>
                    </tr>
                    <tr class="bg-red-lt">
                        <td><span class="badge bg-red">USUNIĘTE</span></td>
                        <td>Juliusz Słowacki</td><td>W pamiętniku Zofii Bobrówny</td><td>IV-VI</td>
                    </tr>
                    <tr class="bg-orange-lt">
                        <td><span class="badge bg-orange">→ UZUPEŁN.</span></td>
                        <td>Bolesław Prus</td><td>Katarynka</td><td>IV-VI</td>
                    </tr>
                    <tr class="bg-orange-lt">
                        <td><span class="badge bg-orange">→ UZUPEŁN.</span></td>
                        <td>Henryk Sienkiewicz</td><td>W pustyni i w puszczy</td><td>IV-VI</td>
                    </tr>
                    <tr class="bg-yellow-lt">
                        <td><span class="badge bg-yellow text-dark">FRAGMENTY</span></td>
                        <td>Adam Mickiewicz</td><td>Pan Tadeusz (tylko ks. I, II, IV, X, XI, XII)</td><td>VII-VIII</td>
                    </tr>
                    <tr class="bg-yellow-lt">
                        <td><span class="badge bg-yellow text-dark">FRAGMENTY</span></td>
                        <td>Henryk Sienkiewicz</td><td>Quo vadis</td><td>VII-VIII</td>
                    </tr>
                    <tr class="bg-yellow-lt">
                        <td><span class="badge bg-yellow text-dark">FRAGMENTY</span></td>
                        <td>Stefan Żeromski</td><td>Syzyfowe prace</td><td>VII-VIII</td>
                    </tr>
                    <tr class="bg-red-lt">
                        <td><span class="badge bg-red">USUNIĘTE</span></td>
                        <td>Ignacy Krasicki</td><td>Żona modna</td><td>VII-VIII</td>
                    </tr>
                    <tr class="bg-red-lt">
                        <td><span class="badge bg-red">USUNIĘTE</span></td>
                        <td>Adam Mickiewicz</td><td>Śmierć Pułkownika</td><td>VII-VIII</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

