                        {a: 'Ernest Hemingway', t: 'Stary człowiek i morze'},
                        {a: 'Rudyard Kipling', t: 'Księga dżungli'},
                        {a: 'Janusz Korczak', t: 'Król Maciuś Pierwszy'},
                        {a: 'Rafał Kosik', t: 'Felix, Net i Nika oraz Gang Niewidzialnych Ludzi'},
                        {a: 'Barbara Kosmowska', t: 'Pozłacana rybka'},
