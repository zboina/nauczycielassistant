    <div class="card-status-start bg-purple"></div>
    <div class="card-header">
        <h3 class="card-title"><i class="ti ti-books me-2"></i>Lektury uzupełniające (klasy IV–VIII)</h3>
        <div class="card-actions"><span class="text-secondary small">Min. 2 rocznie (IV-VI) / 1 rocznie (VII-VIII)</span></div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive" style="max-height:500px;overflow-y:auto;">
            <table class="table table-vcenter table-sm card-table">
                <tbody>
