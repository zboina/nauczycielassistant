                        {a: 'Stanisław Lem', t: 'Cyberiada (fragmenty)'},
                        {a: 'Bolesław Leśmian', t: 'Klechdy sezamowe'},
                        {a: 'A.A. Milne', t: 'Kubuś Puchatek'},
                        {a: 'L.M. Montgomery', t: 'Ania z Zielonego Wzgórza'},
                        {a: 'Małgorzata Musierowicz', t: 'Wybrana powieść'},
                        {a: 'Edmund Niziurski', t: 'Sposób na Alcybiadesa'},
