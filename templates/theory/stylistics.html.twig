{% extends 'base.html.twig' %}

{% block title %}Środki stylistyczne — Nauczyciel Assistant{% endblock %}
{% block pretitle_text %}Teoria{% endblock %}
{% block title_text %}Środki stylistyczne{% endblock %}

{% block page_actions %}
    <a href="{{ path('app_theory_index') }}" class="btn btn-outline-secondary btn-sm"><i class="ti ti-arrow-left me-1"></i>Teoria</a>
{% endblock %}

{% block body %}
{# Level filter tabs #}
<div class="card mb-4">
    <div class="card-body py-3">
        <div class="d-flex gap-2 align-items-center">
            <span class="text-secondary fw-medium small">Filtruj:</span>
            <div class="btn-group" x-data="{level: 'all'}">
                <button class="btn btn-sm" :class="level==='all' ? 'btn-primary' : 'btn-outline-primary'" @click="level='all'; filterDevices('all')">Wszystkie</button>
                <button class="btn btn-sm" :class="level==='4-6' ? 'btn-primary' : 'btn-outline-primary'" @click="level='4-6'; filterDevices('4-6')">Kl. IV–VI</button>
                <button class="btn btn-sm" :class="level==='7-8' ? 'btn-primary' : 'btn-outline-primary'" @click="level='7-8'; filterDevices('7-8')">Kl. VII–VIII</button>
            </div>
        </div>
    </div>
</div>

<div class="row row-cards" id="devicesGrid">
    {% for device in devices %}
        <div class="col-md-6 col-xl-4 device-card" data-level="{{ device.level }}">
            <div class="card h-100">
                <div class="card-status-start {{ device.level == '4-6' ? 'bg-blue' : 'bg-purple' }}"></div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h3 class="card-title mb-0">{{ device.name }}</h3>
                        <span class="badge {{ device.level == '4-6' ? 'bg-blue-lt' : 'bg-purple-lt' }}">kl. {{ device.level }}</span>
                    </div>
                    <p class="text-secondary mb-3" style="font-size:.9rem;">{{ device.definition }}</p>
                    <div class="border rounded p-2 bg-light">
                        <div class="d-flex gap-2 align-items-start">
                            <i class="ti ti-quote text-secondary flex-shrink-0" style="margin-top:2px;"></i>
                            <div style="font-size:.85rem;font-style:italic;">{{ device.example }}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {% endfor %}
</div>

<script>
function filterDevices(level) {
    document.querySelectorAll('.device-card').forEach(card => {
        if (level === 'all' || card.dataset.level === level) {
            card.style.display = '';
        } else {
            card.style.display = 'none';
        }
    });
}
</script>
{% endblock %}
