{% extends 'base.html.twig' %}

{% block title %}Formy wypowiedzi — Nauczyciel Assistant{% endblock %}
{% block pretitle_text %}Teoria{% endblock %}
{% block title_text %}Formy wypowiedzi pisemnej{% endblock %}

{% block page_actions %}
    <a href="{{ path('app_theory_index') }}" class="btn btn-outline-secondary btn-sm"><i class="ti ti-arrow-left me-1"></i>Teoria</a>
{% endblock %}

{% block body %}
<div class="row g-4">
    {# Table of contents #}
    <div class="col-lg-3">
        <div class="card sticky-top" style="top:1rem;">
            <div class="card-header"><h3 class="card-title"><i class="ti ti-list me-2"></i>Spis treści</h3></div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    {% for form in forms %}
                        <a href="#form-{{ loop.index }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            {{ form.name }}
                            <span class="badge {{ form.level == '4-6' or form.level matches '/^[4-6]/' ? 'bg-blue-lt' : 'bg-purple-lt' }}">kl. {{ form.level }}</span>
                        </a>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

    {# Content #}
    <div class="col-lg-9">
        {% for form in forms %}
            {% set isJunior = form.level == '4-6' or form.level matches '/^[4-6]/' %}
            <div class="card mb-3" id="form-{{ loop.index }}">
                <div class="card-status-start {{ isJunior ? 'bg-blue' : 'bg-purple' }}"></div>
                <div class="card-header">
                    <h3 class="card-title">
                        <span class="avatar avatar-sm rounded {{ isJunior ? 'bg-blue-lt' : 'bg-purple-lt' }} me-2" style="font-size:.7rem;">{{ loop.index }}</span>
                        {{ form.name }}
                    </h3>
                    <div class="card-actions">
                        <span class="badge {{ isJunior ? 'bg-blue-lt' : 'bg-purple-lt' }}">kl. {{ form.level }}</span>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row g-4">
                        {# Structure #}
                        <div class="col-md-6">
                            <h4 class="text-uppercase text-secondary small fw-bold mb-3">
                                <i class="ti ti-layout-list me-1"></i>Budowa
                            </h4>
                            <div class="steps steps-vertical">
                                {% for step in form.structure %}
                                    <div class="step-item">
                                        <div class="step-content">
                                            <div class="step-title" style="font-size:.88rem;">{{ step }}</div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>

                        {# Tips #}
                        <div class="col-md-6">
                            <h4 class="text-uppercase text-secondary small fw-bold mb-3">
                                <i class="ti ti-bulb me-1"></i>Wskazówki
                            </h4>
                            {% for tip in form.tips %}
                                <div class="d-flex gap-2 mb-2 align-items-start">
                                    <i class="ti ti-point-filled {{ isJunior ? 'text-blue' : 'text-purple' }} flex-shrink-0" style="margin-top:2px;"></i>
                                    <div style="font-size:.88rem;">{{ tip }}</div>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
